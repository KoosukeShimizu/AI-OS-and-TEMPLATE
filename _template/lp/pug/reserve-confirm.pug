//-================================================
//- サイト共通設定
//-================================================
include _includes/_foundation/_global

//- block vars
//---------------
//- ページ設定
//---------------
- var root = './' // ルートパスの指定
- var key = 'reserve-confirm' // 条件分岐に使用
- var useNoindex = false // noindexの有無
- var useOgp = true // OGPの有無
- var useAnalytics = true // GAタグの有無
- var useLogoH1 = false // ロゴにh1を使うか
- var useBreadcrumb = true // パンくずを使うか

//---------------
//- 構造化データ設定
//---------------
- var useSchemaWebSite = true
- var useSchemaWebPage = true
- var useSchemaOrganization = true
- var useSchemaBreadcrumb = true
- var useSchemaArticle = false
- var useSchemaFAQ = false

//---------------
//- ページメタ情報
//---------------
- var pageTitle = '初回仮予約受付フォーム'
- var pageDescription = 'N2クリニックへのご予約内容をご確認ください。内容に誤りがないかご確認の上、送信ボタンを押してください。'
- var pageKeywords = 'N2クリニック, 初回予約, 初診, 仮予約, フォーム'
- var pageOgUrl = '' // ページ公開後にURLを指定
- var pageOgTitle = pageTitle + '｜N2クリニック'
- var pageOgDescription = pageDescription
- var pageOgImage = '' // OGP画像があれば指定

//---------------
//- パンくず設定
//---------------
- var pageSlug= "reserve-confirm" // ページのスラッグ※末尾に「/」必須
- var parentSlug= "reserve" // ページが3階層目の場合、親ページのスラッグ
- var parentTitle= "予約のご案内" // ページが3階層目の場合、親ページの名前

//- ===================================================
//-  ███████╗████████╗ █████╗ ███████╗ ████████╗
//-  ██╔════╝╚══██╔══╝██╔══██╗██╔═══██╗╚══██╔══╝
//-  ███████╗   ██║   ███████║███████╔╝   ██║
//-  ╚════██║   ██║   ██╔══██║██╔═██║     ██║
//-  ███████║   ██║   ██║  ██║██║ ███║    ██║
//-  ╚══════╝   ╚═╝   ╚═╝  ╚═╝╚═╝ ╚══╝    ╚═╝
//- ===================================================
doctype html
html(lang='ja')
  head
    include _includes/_head
    //---------------------------------
    //- UNIQUE CSS　ページ独自に使用するスタイル
    //---------------------------------
    block append css
      link(href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet")
      link(rel='stylesheet' href=root+cssPath+'main.css?ver=1.0.0' type='text/css' media='all')
    //---------------------------------
    //- SCHEMA　構造化データの呼び出し
    //---------------------------------
    include _includes/_foundation/_schema
    //---------------------------------
    //- 計測タグ（head）の呼び出し
    //---------------------------------
    include _includes/_trackingTag_head
  body.p-confirm
    //---------------------------------
    //- 計測タグ（body）の呼び出し
    //---------------------------------
    include _includes/_trackingTag_body
    .l-wrapper
      //- include _includes/_header
      //- include _includes/_component/_breadcrumb
      header.l-header.p-reserve-header
        .p-reserve-header__logo
          a(href=root+"")
            img(src=root+imgPath+"common/logo-ginza.png" alt=siteName)
      main.l-main.u-anim-fadeIn
        //-================================================
        //- ARTICLE START
        //-================================================
        // Article START
        article.l-page
          // Heroセクション
          .l-page__head
            h1.l-page__title 仮予約受付フォーム
            .l-page__sub WELCOME TO N2 ClINIC GINZA
          .l-page__body
            section.l-section.-xxs
              .l-inner.-xs
                .c-step
                  ul.c-step__list
                    li.c-step__item
                      span.c-step__order STEP1
                      span.c-step__label 情報入力
                    li.c-step__item.is-current
                      span.c-step__order STEP2
                      span.c-step__label 内容確認
                    li.c-step__item
                      span.c-step__order STEP3
                      span.c-step__label 仮予約完了
                

                form(method="post" action=root+"inquiry-thanks"+extention enctype="multipart/form-data")
                  .c-form__item
                      .c-form__error ※プライバシーポリシーに同意の上、ご送信ください。
                  dl.p-confirm-list.u-mb-xl
                    dt ■ 希望予約内容
                    dd %formData.subject%
                    input(type="hidden" name="subject" value="formData.subject")

                    dt ■ お名前（ローマ字）
                    dd %formData.name%
                    input(type="hidden" name="name" value="formData.name")

                    //- dt フリガナ
                    //- dd %formData.kana%
                    //- input(type="hidden" name="kana" value="formData.kana")

                    dt ■ 電話番号
                    dd %formData.tel%
                    input(type="hidden" name="tel" value="formData.tel")
                    
                    dt ■ メールアドレス
                    dd %formData.email%
                    input(type="hidden" name="email" value="formData.email")

                    dt ■ 生年月日
                    dd %formData.birth%
                    input(type="hidden" name="birth" value="formData.birth")

                    dt ■ 性別
                    dd %formData.gender%
                    input(type="hidden" name="gender" value="formData.gender")

                    

                    dt 予約希望日時
                    dd 第１希望：7/10（火）午後#[br]第２希望：7/12（木）午前#[br]第３希望：7/13（金）夕方
                    input(type="hidden" name="daytime1" value="formData.daytime1")
                    input(type="hidden" name="daytime2" value="formData.daytime2")
                    input(type="hidden" name="daytime3" value="formData.daytime3")

                    dt 連絡方法
                    dd どちらでも
                    input(type="hidden" name="contact" value="formData.address")

                    //- 会社名（法人系フォームで使用）
                    //- dt 会社名
                    //- dd %formData.company%
                    //- input(type="hidden" name="company" value="formData.company")

                    

                    dt ■ メッセージ
                    dd.u-t-c %formData.message%
                    input(type="hidden" name="message" value="formData.message")

                    //- 複数選択系（チェックボックスの例）
                    // dt ご希望内容
                    // dd %formData.options%
                    // input(type="hidden" name="options" value="formData.options")

                    //- 同意確認
                    // dt 個人情報取扱いへの同意
                    // dd %formData.agree%
                    // input(type="hidden" name="agree" value="formData.agree")

                    //- // 同意事項
                  .c-form__item.u-t-c
                    label.c-form__checkbox
                      input(type="checkbox" name="agree" data-agree-trigger required data-validate="required")
                      span #[a.c-link(href=root+"privacy"+extention) プライバシーポリシー]に同意します＊

                  // 送信ボタン
                  .c-btnBox.u-fd-col
                    button.c-btn.-submit(type="submit" disabled data-agree-target) 送信する
                    button(type="button" onclick="history.back()") やり直す

        //-================================================
        //- Article END
        //-================================================
        // Article END
      //- include _includes/_sidebar
      //- include _includes/_component/_floatbox
      //- include _includes/_footer
    //- include _includes/_script
    //---------------------------------
    //- UNIQUE SCRIPT　ページ独自に使用するJS
    //---------------------------------
    block append js
      script(src=root+jsPath + "main.js?ver=1.0.0")
      script(src=root+jsPath + "form.js?ver=1.0.0")