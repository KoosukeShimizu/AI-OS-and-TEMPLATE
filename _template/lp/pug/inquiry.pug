//-================================================
//- サイト共通設定
//-================================================
include _includes/_foundation/_global

//- block vars
//---------------
//- ページ設定
//---------------
- var root = './' // ルートパスの指定
- var key = 'inquiry' // 条件分岐に使用
- var useNoindex = false // noindexの有無（検索対象にする想定でfalse）
- var useOgp = true // OGPの有無
- var useAnalytics = true // GAタグの有無
- var useLogoH1 = false // ロゴにh1を使うか
- var useBreadcrumb = true // パンくずを使うか

//---------------
//- 構造化データ設定
//---------------
- var useSchemaWebSite = true
- var useSchemaWebPage = true
- var useSchemaOrganization = false
- var useSchemaBreadcrumb = true
- var useSchemaArticle = false
- var useSchemaFAQ = false

//---------------
//- ページメタ情報
//---------------
- var pageTitle = 'お問い合わせ'
- var pageDescription = 'N2クリニックへのお問い合わせはこちらのページから承っております。ご質問やご相談などお気軽にご連絡ください。'
- var pageKeywords = 'お問い合わせ,N2クリニック,連絡'
- var pageOgUrl = '' // ページ公開後にURLを指定
- var pageOgTitle = pageTitle + '｜N2クリニック'
- var pageOgDescription = pageDescription
- var pageOgImage = '' // OGP画像があれば指定

//---------------
//- パンくず設定
//---------------
- var pageSlug= "inquiry" // ページのスラッグ※末尾に「/」必須
- var parentSlug= "" // ページが3階層目の場合、親ページのスラッグ
- var parentTitle= "" // ページが3階層目の場合、親ページの名前

//- ===================================================
//-  ███████╗████████╗ █████╗ ███████╗ ████████╗
//-  ██╔════╝╚══██╔══╝██╔══██╗██╔═══██╗╚══██╔══╝
//-  ███████╗   ██║   ███████║███████╔╝   ██║
//-  ╚════██║   ██║   ██╔══██║██╔═██║     ██║
//-  ███████║   ██║   ██║  ██║██║ ███║    ██║
//-  ╚══════╝   ╚═╝   ╚═╝  ╚═╝╚═╝ ╚══╝    ╚═╝
//- ===================================================
doctype html
html(lang='ja')
  head
    include _includes/_head
    //---------------------------------
    //- UNIQUE CSS　ページ独自に使用するスタイル
    //---------------------------------
    block append css
      link(href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet")
      link(rel='stylesheet' href=root+cssPath+'main.css?ver=1.0.0' type='text/css' media='all')
    //---------------------------------
    //- SCHEMA　構造化データの呼び出し
    //---------------------------------
    include _includes/_foundation/_schema
    //---------------------------------
    //- 計測タグ（head）の呼び出し
    //---------------------------------
    include _includes/_trackingTag_head
  body.p-inquiry
    //---------------------------------
    //- 計測タグ（body）の呼び出し
    //---------------------------------
    include _includes/_trackingTag_body
    .l-wrapper
      include _includes/_header
      include _includes/_component/_breadcrumb
      main.l-main.u-anim-fadeIn
        //-================================================
        //- ARTICLE START
        //-================================================
        // Article START
        article.l-page
          // Heroセクション
          .l-page__head
            h1.l-page__title お問い合わせ
            .l-page__sub Inquiry
            .l-page__intro お問い合わせありがとうございます。#[br]こちらはN2 CLINIC GINZA専用のお問い合わせページです。
          .l-page__body
            section.l-section.-s
              .l-inner.-xs
                //-================================================
                //- お問い合わせフォーム（data属性 + バリデーション対応済 + コメントアウト含む）
                //-================================================

                form(method="post" action=root+"inquiry-confirm"+extention enctype="multipart/form-data")
                  .c-form
                    .c-form__item
                      .c-form__error ※メールアドレスが一致しません。もう一度ご確認ください。
                      .c-form__error ※必須項目が未入力です。ご入力をお願いします。
                      .c-form__error ※電話番号は【国番号付き・半角数字・ハイフンなし】でご入力ください。
                      .c-form__error ※メールアドレスは半角英数字でご入力ください。
                      .c-form__error ※お名前はローマ字（パスポート表記）でご入力ください。

                    // ご用件
                    .c-form__item
                      .c-form__label ご用件
                        span.c-form__require ＊
                      .c-form__body
                        select.c-form__select(name="inquiry" required data-validate="required")
                          option(value="") ご選択ください
                          - var list = ["診療内容について","料金について","予約変更／キャンセル","その他"]
                          each item in list
                            option(value=item) #{item}
                        //- //.c-form__error ご用件を選択してください

                    // 名前（フルネーム版）
                    .c-form__item
                      .c-form__label お名前
                        span.c-text.-small.u-m-0 (ローマ字)
                        span.c-form__require ＊
                      .c-form__body
                        input.c-form__input(type="text" id="name" name="name" placeholder="例：HANAKO YAMADA" autocomplete="name" required data-validate="required")
                        .c-note ※パスポート表記と同じ順（名 → ミドルネーム → 姓）で、ローマ字でご入力ください。
                      //- //.c-form__error お名前を入力してください

                    //- // 氏名（分割版）
                    //- .c-form__item
                      .c-form__label お名前
                        span.c-form__require ＊
                      .c-form__body.-row
                        input.c-form__input(type="text" id="name_sei" name="name_sei" placeholder="姓" autocomplete="family-name" required data-validate="required" data-autokana-source)
                        input.c-form__input(type="text" id="name_mei" name="name_mei" placeholder="名" autocomplete="given-name" required data-validate="required")
                      //.c-form__error お名前を入力してください

                    //- // ふりがな（分割版）
                    //- .c-form__item
                      .c-form__label ふりがな
                        span.c-form__require ＊
                      .c-form__body.-row
                        input.c-form__input(type="text" id="name_kana_sei" name="name_kana_sei" placeholder="せい" required data-validate="required kana" data-autokana-target)
                        input.c-form__input(type="text" id="name_kana_mei" name="name_kana_mei" placeholder="めい" required data-validate="required kana")
                      //.c-form__error ふりがなを入力してください

                    // 電話番号
                    .c-form__item
                      .c-form__label お電話番号
                        span.c-form__require ＊
                      .c-form__body.-row
                        select.c-form__select.u-w-10(name="country-code" id="country-code" required data-validate="required")
                          optgroup(label="アジア")
                            option(value="+81" selected) 🇯🇵 日本 (+81)
                            option(value="+86") 🇨🇳 中国 (+86)
                            option(value="+82") 🇰🇷 韓国 (+82)
                            option(value="+84") 🇻🇳 ベトナム (+84)
                            option(value="+852") 🇭🇰 香港 (+852)
                            option(value="+886") 🇹🇼 台湾 (+886)
                            option(value="+91") 🇮🇳 インド (+91)
                            option(value="+66") 🇹🇭 タイ (+66)
                            option(value="+62") 🇮🇩 インドネシア (+62)
                            option(value="+65") 🇸🇬 シンガポール (+65)
                            option(value="+60") 🇲🇾 マレーシア (+60)
                            option(value="+855") 🇰🇭 カンボジア (+855)
                            option(value="+856") 🇱🇦 ラオス (+856)
                            option(value="+95") 🇲🇲 ミャンマー (+95)
                            option(value="+880") 🇧🇩 バングラデシュ (+880)
                            option(value="+92") 🇵🇰 パキスタン (+92)
                            option(value="+63") 🇵🇭 フィリピン (+63)
                            option(value="+977") 🇳🇵 ネパール (+977)

                          optgroup(label="ヨーロッパ")
                            option(value="+44") 🇬🇧 イギリス (+44)
                            option(value="+49") 🇩🇪 ドイツ (+49)
                            option(value="+33") 🇫🇷 フランス (+33)
                            option(value="+39") 🇮🇹 イタリア (+39)
                            option(value="+34") 🇪🇸 スペイン (+34)
                            option(value="+31") 🇳🇱 オランダ (+31)
                            option(value="+46") 🇸🇪 スウェーデン (+46)
                            option(value="+47") 🇳🇴 ノルウェー (+47)
                            option(value="+41") 🇨🇭 スイス (+41)
                            option(value="+45") 🇩🇰 デンマーク (+45)
                            option(value="+351") 🇵🇹 ポルトガル (+351)
                            option(value="+40") 🇷🇴 ルーマニア (+40)
                            option(value="+30") 🇬🇷 ギリシャ (+30)
                            option(value="+420") 🇨🇿 チェコ (+420)
                            option(value="+36") 🇭🇺 ハンガリー (+36)
                            option(value="+32") 🇧🇪 ベルギー (+32)
                            option(value="+7") 🇷🇺 ロシア (+7)

                          optgroup(label="北米")
                            option(value="+1") 🇺🇸 アメリカ (+1)
                            option(value="+1") 🇨🇦 カナダ (+1)
                            option(value="+52") 🇲🇽 メキシコ (+52)

                          optgroup(label="南米")
                            option(value="+55") 🇧🇷 ブラジル (+55)
                            option(value="+54") 🇦🇷 アルゼンチン (+54)
                            option(value="+57") 🇨🇴 コロンビア (+57)
                            option(value="+56") 🇨🇱 チリ (+56)
                            option(value="+51") 🇵🇪 ペルー (+51)

                          optgroup(label="中東")
                            option(value="+90") 🇹🇷 トルコ (+90)
                            option(value="+971") 🇦🇪 アラブ首長国連邦 (+971)
                            option(value="+966") 🇸🇦 サウジアラビア (+966)
                            option(value="+972") 🇮🇱 イスラエル (+972)
                            option(value="+20") 🇪🇬 エジプト (+20)

                          optgroup(label="アフリカ")
                            option(value="+27") 🇿🇦 南アフリカ (+27)
                            option(value="+234") 🇳🇬 ナイジェリア (+234)
                            option(value="+212") 🇲🇦 モロッコ (+212)
                            option(value="+254") 🇰🇪 ケニア (+254)

                          optgroup(label="オセアニア")
                            option(value="+61") 🇦🇺 オーストラリア (+61)
                            option(value="+64") 🇳🇿 ニュージーランド (+64)
                            option(value="+679") 🇫🇯 フィジー (+679)
                        input.c-form__input(type="tel" id="tel" name="tel" placeholder="例：312345678" autocomplete="tel" maxlength="13" required data-validate="required tel")
                        .c-note ※ 国番号を選択し、半角数字でご入力ください（ハイフン不要）
                        //- //.c-form__error 電話番号を入力してください


                    // メールアドレス
                    .c-form__item
                      .c-form__label メールアドレス
                        span.c-form__require ＊
                      .c-form__body
                        input.c-form__input(type="email" id="email" name="email" placeholder="例：yourname@example.com" autocomplete="email" required data-validate="required email")
                        .c-note ※半角英数字でご入力ください
                        //- //.c-form__error メールアドレスを入力してください
                    // メールアドレス（確認用）
                    .c-form__item
                      .c-form__label メールアドレス
                        span.c-text.-small.u-m-0 確認用
                        span.c-form__require ＊
                        //- span.c-text.-small.u-m-0 （確認用）
                      .c-form__body
                        input.c-form__input(type="email" id="email_confirm" name="email_confirm" placeholder="例：yourname@example.com" autocomplete="email" required data-validate="required email match" data-match="email")
                        .c-note ※もう一度ご入力ください
                      //- //.c-form__error メールアドレス（確認用）を入力してください

                    

                    //- // 性別
                    //- .c-form__item
                      .c-form__label 性別
                        span.c-form__require ＊
                      .c-form__body.-row
                        label.c-form__radio
                          input(type="radio" name="gender" value="男性" required data-validate="required")
                          span 男性
                        label.c-form__radio
                          input(type="radio" name="gender" value="女性")
                          span 女性
                      //.c-form__error 性別を選択してください

                    //- // 生年月日
                    //- .c-form__item
                      .c-form__label 生年月日
                        span.c-form__require ＊
                      .c-form__body.-row
                        select.c-form__select(name="bd-year" autocomplete="bday-year" required data-validate="required")
                          option(value="") ----
                          - for(var n = 1960; n <= 2022; n++)
                            option(value=n) #{n}
                        span 年
                        select.c-form__select(name="bday-month" autocomplete="bday-month" required data-validate="required")
                          option(value="") --
                          - for(var n = 1; n <= 12; n++)
                            option(value=n) #{n}
                        span 月
                        select.c-form__select(name="bday-day" autocomplete="bday-day" required data-validate="required")
                          option(value="") --
                          - for(var n = 1; n <= 31; n++)
                            option(value=n) #{n}
                        span 日
                      //.c-form__error 生年月日を選択してください

                    //- // 住所
                    //- .h-adr
                      input.p-country-name(type="hidden" value="Japan")

                      .c-form__item
                        .c-form__label 郵便番号
                          span.c-form__require ＊
                        .c-form__body
                          span 〒
                          input.c-form__input.p-postal-code(type="text" id="postal-code" name="postal-code" placeholder="例：123-4567" size="8" maxlength="8" required data-validate="required postal")
                        //.c-form__error 郵便番号を入力してください

                      .c-form__item
                        .c-form__label 都道府県
                          span.c-form__require ＊
                        .c-form__body
                          select.c-form__select.p-region-id.-inline(name="address-level1" autocomplete="address-level1" required data-validate="required")
                            option(value="") 選択してください
                            include _includes/_component/_prefecture
                        //.c-form__error 都道府県を選択してください

                      .c-form__item
                        .c-form__label 市区町村
                          span.c-form__require ＊
                        .c-form__body
                          input.c-form__input.p-locality(type="text" name="address-level2" autocomplete="address-level2" required data-validate="required")
                        //.c-form__error 市区町村を入力してください

                      .c-form__item
                        .c-form__label 市区町村以降
                          span.c-form__require ＊
                        .c-form__body
                          input.c-form__input.p-street-address.p-extended-address(type="text" name="address-level3" autocomplete="address-level3" required data-validate="required")
                        //.c-form__error 市区町村以降を入力してください

                      .c-form__item
                        .c-form__label 建物名など
                        .c-form__body
                          input.c-form__input(type="text" name="address-level4" autocomplete="address-level4")

                    //- // ご連絡可能時間
                    //- .c-form__item
                      .c-form__label ご連絡可能時間
                        span.c-form__require ＊
                      .c-form__body
                        label.c-form__checkbox
                          input(type="checkbox" name="period" value="午前中" required data-validate="required")
                          span 午前中（10時〜12時）
                        label.c-form__checkbox
                          input(type="checkbox" name="period" value="午後")
                          span 午後（13時〜15時）
                        label.c-form__checkbox
                          input(type="checkbox" name="period" value="夕方")
                          span 夕方（16時〜18時）
                        label.c-form__checkbox
                          input(type="checkbox" name="period" value="夜")
                          span 夜（19時〜21時）
                      //.c-form__error ご連絡可能時間を選択してください

                    // メッセージ
                    .c-form__item
                      .c-form__label メッセージ
                        //- span.c-form__require ＊
                      .c-form__body
                        textarea.c-form__textarea(name="comment" placeholder="メッセージを具体的にお知らせください。" data-autoresize)
                      //- //.c-form__error メッセージを入力してください

                    //- // 同意事項
                    //- .c-form__agree
                      .c-form__agree__title 同意事項
                      .c-form__agree__text 当フォームのご利用には、下記事項のご確認とご同意が必要です。
                      .c-form__agree__body
                        ul
                          li ご連絡までお時間がかかることがございます。
                          li プライバシーポリシーに同意してください。
                        label.c-form__checkbox
                          input(type="checkbox" name="agree" data-agree-trigger required data-validate="required")
                          span 上記に同意します

                    //- // 送信
                    //- .c-form__submit
                      button.c-button-submit(type="submit" data-submit-button) 入力内容を確認する

                  // 送信ボタン
                  .c-btnBox.u-gap-l.u-mt-l
                    //- button.c-btn.-underline(type="reset") リセット
                    button.c-btn.-underline(type="submit") 送信内容の確認



        //-================================================
        //- Article END
        //-================================================
        // Article END
      //- include _includes/_sidebar
      //- include _includes/_component/_floatbox
      include _includes/_footer
    //- include _includes/_script
    //---------------------------------
    //- UNIQUE SCRIPT　ページ独自に使用するJS
    //---------------------------------
    block append js
      script(src=root+jsPath + "main.js?ver=1.0.0")
      script(src=root+jsPath + "form.js?ver=1.0.0")
