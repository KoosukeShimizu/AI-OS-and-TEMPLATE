doctype html
html(lang='ja')
  head
    include _includes/_head
    //---------------------------------
    //- UNIQUE CSSページ独自に使用するスタイル
    //---------------------------------
    block append css
      link(href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet")
      link(rel='stylesheet' href=root+cssPath+'main.css?ver=1.0.0' type='text/css' media='all')

    //---------------------------------
    //- SCHEMA構造化データの呼び出し
    //---------------------------------
    include _includes/_foundation/_schema
    //---------------------------------
    //- 計測タグ（head）の呼び出し
    //---------------------------------
    include _includes/_trackingTag_head
  body.p-about
    //---------------------------------
    //- 計測タグ（body）の呼び出し
    //---------------------------------
    include _includes/_trackingTag_body
    .l-wrapper
      include _includes/_header
      include _includes/_component/_breadcrumb
      main.l-main.u-anim-fadeIn
        //-================================================
        //- ARTICLE START
        //-================================================
        // Article START
        article.l-page

          // ヒーローセクション
          .l-page__head
            h1.l-page__title N2クリニックとは
            .l-page__sub ABOUT US
            figure.l-page__kv
              img(src=root+imgPath+"about/about-kv.jpg"+version alt="採用情報メインビジュアル" loading="lazy")

          .l-page__body
            // リード文
            section.l-section.-xs
              .l-inner.u-t-c
                h2.c-heading.-h2.u-mb-0 N2クリニックの歩み
                .c-subTitle.u-mb-xl 〜 再生医療の頂を目指して〜
                .c-text 2015年、東京・代官山にて、N2クリニックは誕生しました。#[br]再生医療がまだ一般に広く知られていなかった時代、#[br.u-hide-sp]私たちは幹細胞および免疫細胞に特化した専門クリニックとして、#[br.u-hide-sp]「科学に基づいた、真の予防と若さの追求」という明確なビジョンを掲げ、歩みを始めました。
                .c-text 2024年には、日本が世界で初めて「再生医療等の安全性の確保等に関する法律」を施行。#[br]N2クリニックは、厚生労働省への届出・厳格な審査を経て、認可を受け、#[br.u-hide-sp]法制度に完全準拠した再生医療の提供機関として、その信頼を築いてまいりました。


            // セクション：拠点展開
            section.l-section.p-about-location(data-inview="slideUp")
              .l-inner.-l
                .p-about-location__block
                  figure.p-about-location__image
                    img(src=root+imgPath+"about/about-1-1.jpg" alt="東京タワーのイメージ" loading="lazy")
                  .p-about-location__text
                    h2.c-heading.-h2 世界中の富裕層に応える拠点展開
                    .c-text 増加する国内外からのニーズに応えるべく、私たちは次のステージへと進みました。
                    ul.c-list.-dot
                      li 2014年 ─ 東京都渋谷区代官山にN2クリニック代官山初開院
                      li 2021年 ─ 東京都千代田区「ホテル椿山荘東京」内に、N2クリニック ホテル椿山荘東京院を開院
                      li 2022年 ─ 東京・四谷にて、N2クリニック四谷院を開院
                      li 2022年 ─ 海外展開として、N2クリニック ベトナムを開院
                      li 2025年 ─ 銀座院を移転・拡張し、N2クリニック銀座本院として再始動。より洗練された空間と医療体制を整えました。
                    .c-text N2クリニックは、10年にわたる信頼と実績をもとに、アジアにおける再生医療のリーディングクリニックとして、世界中の方々の「真の健康と若さ」の実現をサポートしてまいります。
                    .c-btnBox.u-mt-xl
                      a.c-btn.-underline(href="https://n2clinic-chinzanso.com/") 椿山荘院はこちら
                      a.c-btn.-underline(href="https://n2clinic-yotsuya.com/") 四谷院はこちら
                      a.c-btn.-underline(href="https://n2clinic.vn/") ベトナム院はこちら
                  
                  





            //-================================================
            //- 認定医療・取組紹介セクション
            //-================================================

            section#creafied.l-section.p-about-certification.-bg-secondary(data-inview="slideUp")
              .l-inner.-l
                //- セクションタイトル
                .c-subTitle.-center CERTIFIED
                h2.c-heading.-section 国の認可を受けた確かな医療

                //- 動画エリア
                figure.c-video.u-mb-xxl.u-w-edge-sp
                  iframe(
                    src="https://www.youtube.com/embed/XZYBLsT2CmE" 
                    title="認定医療紹介動画"
                    frameborder="0" 
                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                    allowfullscreen
                  )

                //- 安全性の取組（説明＋イメージ）
                .p-about-certification__block.-reverse.u-mb-l
                  .p-about-certification__image
                    img(src=root+imgPath+"about/about-2-1.jpg" alt="細胞治療イメージ" loading="lazy")
                  .p-about-certification__text
                    h3.c-heading.-h3 安全性と有効性を両立するための揺るぎない基準
                    p.c-text 治療は全て厚生労働省認定の特定認定再生医療等委員会による審査を経て、「再生医療提供計画番号」を取得したうえで実施しています。
                    p.c-text 国の認可を受けたプロトコルに基づき、安全性と有効性が厳格に担保された医療をご提供し、患者さまには安心して最先端の再生医療をお受けいただける体制を整えています。
                  

                //- 医療連携とエビデンス構築
                .p-about-certification__block.u-mb-l
                  .p-about-certification__image
                    img(src=root+imgPath+"about/about-2-2.jpg" alt="研究ラボイメージ" loading="lazy")
                  .p-about-certification__text
                    h3.c-heading.-h3 医療連携とエビデンス構築への取り組み
                    ul.c-list.-dot.u-mt-0
                      li 都内大学病院・総合病院との連携#[br]緊急時の検査や専門的な対応が必要な場合にもすぐに連携できる体制を構築。 どのようなケースにも迅速に最適な医療を提供できることが、患者様の安心につながります。
                      li 院内外の臨床研究と最新情報のキャッチアップ#[br]国内外の最新研究情報を常に確認し、院内で臨床研究を行うことでエビデンスを蓄積。その成果を速やかに治療に反映し、安全かつ効果的なプロトコルを維持しています。


                //- 細胞培養品質
                .p-about-certification__block.-reverse
                  .p-about-certification__image
                    img(src=root+imgPath+"about/about-2-3.jpg" alt="細胞培養イメージ" loading="lazy")
                  .p-about-certification__text
                    h3.c-heading.-h3 こだわり抜いた細胞培養の品質
                    .c-text 再生医療において、治療に用いる細胞の品質や、それを支える技術の信頼性は非常に重要です。
                    .c-text 当クリニックの治療を支える細胞培養は、N2クリニック四谷院長が代表を務めるバイオセラピー研究所との連携により、高度な品質管理・無菌環境・正確性のもとで行われています。
                    .c-text 私たちは、患者様一人ひとりに安心して治療を受けていただける環境を提供し、すべての細胞製品において、富裕層のお客様の期待に応える最高水準の安全性と品質を保証いたします。





            //-================================================
            //- 認定書類セクション
            //-================================================

            section.l-section.p-about-license.-bg-secondary(data-inview="slideUp")
              .l-inner.-l
                .c-text.-center.u-mb-l 以下は、厚生労働省認定特定 再生医療等委員会より発行された、当院の再生医療提供計画番号取得を証明する認可書類です。#[br]国の厳格な審査を経て取得した計画番号は、当院の取り組みと信頼を裏付けるものです。（一部抜粋）

                .p-about-license__list
                  // 1枚目
                  .p-about-license__item
                    figure
                      img(src=root+imgPath+"about/about-3-1.jpg" alt="認定書類1" loading="lazy")
                      figcaption ※書類の一部を表示しています。#[br]全文は院内でご確認いただけます。
                    //- .p-about-license__number
                      .c-text-small 再生医療提供計画番号
                      .c-text 01C2501037

                  // 2枚目
                  .p-about-license__item
                    figure
                      img(src=root+imgPath+"about/about-3-2.jpg" alt="認定書類2" loading="lazy")
                      figcaption ※書類の一部を表示しています。#[br]全文は院内でご確認いただけます。
                    //- .p-about-license__number
                      .c-text-small 再生医療提供計画番号
                      .c-text 01C2501036

                  // 3枚目
                  .p-about-license__item
                    figure
                      img(src=root+imgPath+"about/about-3-3.jpg" alt="認定書類3" loading="lazy")
                      figcaption ※書類の一部を表示しています。#[br]全文は院内でご確認いただけます。
                    //- .p-about-license__number
                      .c-text-small 再生医療提供計画番号
                      .c-text 01C2501035

                  // 4枚目
                  .p-about-license__item
                    figure
                      img(src=root+imgPath+"about/about-3-4.jpg" alt="認定書類4" loading="lazy")
                      figcaption ※書類の一部を表示しています。#[br]全文は院内でご確認いただけます。
                    //- .p-about-license__number
                      .c-text-small 再生医療提供計画番号
                      .c-text 01C2501034

                  // 5枚目
                  .p-about-license__item
                    figure
                      img(src=root+imgPath+"about/about-3-5.jpg" alt="認定書類5" loading="lazy")
                      figcaption ※書類の一部を表示しています。#[br]全文は院内でご確認いただけます。
                    //- .p-about-license__number
                      .c-text-small 再生医療提供計画番号
                      .c-text 01C2501033

                  // 6枚目
                  .p-about-license__item
                    figure
                      img(src=root+imgPath+"about/about-3-6.jpg" alt="認定書類6" loading="lazy")
                      figcaption ※書類の一部を表示しています。#[br]全文は院内でご確認いただけます。
                    //- .p-about-license__number
                      .c-text-small 再生医療提供計画番号
                      .c-text 01C2501032

                
                .c-accordion
                  .c-accordion__item
                    button.c-accordion__title.u-mb-xl(type="button" data-accordion-trigger)  その他の提供計画も見る
                    .c-accordion__content(data-accordion-content hidden)
                      .p-about-license__list
                        // 1枚目
                        .p-about-license__item
                          figure
                            img(src=root+imgPath+"about/about-3-7.jpg" alt="認定書類1" loading="lazy")
                            figcaption ※書類の一部を表示しています。#[br]全文は院内でご確認いただけます。
                          //- .p-about-license__number
                            .c-text-small 再生医療提供計画番号
                            .c-text 01C2501031

                        // 2枚目
                        .p-about-license__item
                          figure
                            img(src=root+imgPath+"about/about-3-8.jpg" alt="認定書類2" loading="lazy")
                            figcaption ※書類の一部を表示しています。#[br]全文は院内でご確認いただけます。
                          //- .p-about-license__number
                            .c-text-small 再生医療提供計画番号
                            .c-text 01C2501030

                        // 3枚目
                        .p-about-license__item
                          figure
                            img(src=root+imgPath+"about/about-3-9.jpg" alt="認定書類3" loading="lazy")
                            figcaption ※書類の一部を表示しています。#[br]全文は院内でご確認いただけます。
                          //- .p-about-license__number
                            .c-text-small 再生医療提供計画番号
                            .c-text 01C2501029

                        // 4枚目
                        .p-about-license__item
                          figure
                            img(src=root+imgPath+"about/about-3-10.jpg" alt="認定書類4" loading="lazy")
                            figcaption ※書類の一部を表示しています。#[br]全文は院内でご確認いただけます。
                          //- .p-about-license__number
