            // アクセスセクション
            section#access.l-section.p-about-access.u-pb-0
              .l-inner.-l.u-t-c
                .c-subTitle ACCESS
                h2.c-heading.-h2.u-mb-xl クリニックへのご案内

                ul 
                .c-text N2クリニック銀座本院
                .c-text 住所：東京都中央区銀座6丁目6-5 HULIC &New GINZA NAMIKI6 11階
                .c-text TEL：03-3289-0202
                .c-text 診療時間：10:00〜18:30#[br]休診日：日曜日
                .c-text 最寄駅#[br]各線銀座駅B5番出口より 徒歩4分

                .c-btnBox.-right.u-mb-m #[a.c-btn.-underline(href='https://www.google.com/maps?ll=35.67094,139.762513&z=16&t=m&hl=ja&gl=JP&mapclient=embed&cid=2743125638156727850' target="_blank") マップへ]

