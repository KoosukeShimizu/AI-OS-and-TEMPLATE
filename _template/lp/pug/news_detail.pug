doctype html
html(lang='ja')
  head
    include _includes/_head
    //---------------------------------
    //- UNIQUE CSS　ページ独自に使用するスタイル
    //---------------------------------
    block append css
      link(href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet")
      link(rel='stylesheet' href=root+cssPath+'main.css?ver=1.0.0' type='text/css' media='all')
    //---------------------------------
    //- SCHEMA　構造化データの呼び出し
    //---------------------------------
    include _includes/_foundation/_schema
    //---------------------------------
    //- 計測タグ（head）の呼び出し
    //---------------------------------
    include _includes/_trackingTag_head
  body.p-news
    //---------------------------------
    //- 計測タグ（body）の呼び出し
    //---------------------------------
    include _includes/_trackingTag_body
    .l-wrapper
      include _includes/_header
      include _includes/_component/_breadcrumb
      main.l-main.u-anim-fadeIn
        //-================================================
        //- ARTICLE START
        //-================================================
        // Article START
        article.l-article
          // Heroセクション
          .l-article__head
            time.l-article__time(datetime="2025.07.07") 2025.07.07
            h1.l-article__title N2 CLINIC GINZAは移転いたしました。
            //- .l-article__tags
              a.c-tag(href=root+"tag1"+extention) タグ1
              a.c-tag-red(href=root+"tag2"+extention) タグ2
              a.c-tag-blue(href=root+"tag3"+extention) タグ3
            
            //- figure.l-article__hero
                img(src=root+imgPath+"common/dummy-l.png" loading="lazy"  width="" height="" alt="")

          //- details.c-toc(open)
            summary.c-toc__title index
            #js-toc.c-toc__body

          .l-article__body
            //- .l-inner.-xs
            .p-editor
              // CMS EDIT CONTENT START
              // ここからはCMSで入力された内容が反映されます。
              //  .p-single-content配下はセレクタにスタイルを設定し、クラス付与無しで見た目が整うようにしてください。
              p クリニック移転のご案内
              p 拝啓 #[br]#[br]皆様におかれましては、益々ご健勝のこととお慶び申し上げます。#[br]平素よりN2 CLINIC GINZAをご愛顧いただき、心より御礼申し上げます。
              p さて、このたびN2 CLINIC GINZAは業務拡大およびサービス向上のため、2025年1月11日をもちまして下記の新住所へ移転する運びとなりました。これを機に、より一層皆様のお役に立てるクリニックを目指して努力してまいります。
              p 新クリニックは、これまで以上に快適で利便性の高い環境をご提供できるよう配慮いたしました。新しい場所でも、変わらぬご愛顧を賜りますようお願い申し上げます。
              p 新住所：東京都中央区銀座6-6-5 HulicGinza Namiki6 11F#[br]移転日：2025年1月11日
              p 皆様には移転に伴い何かとご不便をおかけすることもあるかと存じますが、引き続き変わらぬお引き立てを賜りますようお願い申し上げます。
              p まずは略儀ながら、書中をもちましてご挨拶申し上げます。
              p N2 CLINIC　一同
              h2 <移転先へのアクセス>
