//-================================================
//- サイト共通設定
//-================================================
include _includes/_foundation/_global

//- block vars
//---------------
//- ページ設定
//---------------
- var root = './' // ルートパスの指定
- var key = 'inquiry-confirm' // 条件分岐に使用
- var useNoindex = true // noindexの有無
- var useOgp = false // OGPの有無
- var useAnalytics = false // GAタグの有無
- var useLogoH1 = false // ロゴにh1を使うか
- var useBreadcrumb = false // パンくずを使うか

//---------------
//- 構造化データ設定
//---------------
- var useSchemaWebSite = true
- var useSchemaWebPage = false
- var useSchemaOrganization = false
- var useSchemaBreadcrumb = false
- var useSchemaArticle = false
- var useSchemaFAQ = false

//---------------
//- ページメタ情報
//---------------
- var pageTitle = 'お問い合わせ確認'
- var pageDescription = 'N2クリニックへのお問い合わせ内容をご確認ください。内容に誤りがないかご確認の上、送信ボタンを押してください。'
- var pageKeywords = 'お問い合わせ,N2クリニック,連絡'
- var pageOgUrl = '' // ページ公開後にURLを指定
- var pageOgTitle = pageTitle + '｜N2クリニック'
- var pageOgDescription = pageDescription
- var pageOgImage = '' // OGP画像があれば指定

//---------------
//- パンくず設定
//---------------
- var pageSlug= "inquiry-confirm" // ページのスラッグ※末尾に「/」必須
- var parentSlug= "inquiry" // ページが3階層目の場合、親ページのスラッグ
- var parentTitle= "お問い合わせ" // ページが3階層目の場合、親ページの名前

//- ===================================================
//-  ███████╗████████╗ █████╗ ███████╗ ████████╗
//-  ██╔════╝╚══██╔══╝██╔══██╗██╔═══██╗╚══██╔══╝
//-  ███████╗   ██║   ███████║███████╔╝   ██║
//-  ╚════██║   ██║   ██╔══██║██╔═██║     ██║
//-  ███████║   ██║   ██║  ██║██║ ███║    ██║
//-  ╚══════╝   ╚═╝   ╚═╝  ╚═╝╚═╝ ╚══╝    ╚═╝
//- ===================================================
doctype html
html(lang='ja')
  head
    include _includes/_head
    //---------------------------------
    //- UNIQUE CSS　ページ独自に使用するスタイル
    //---------------------------------
    block append css
      link(href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet")
      link(rel='stylesheet' href=root+cssPath+'main.css?ver=1.0.0' type='text/css' media='all')
    //---------------------------------
    //- SCHEMA　構造化データの呼び出し
    //---------------------------------
    include _includes/_foundation/_schema
    //---------------------------------
    //- 計測タグ（head）の呼び出し
    //---------------------------------
    include _includes/_trackingTag_head
  body.p-confirm
    //---------------------------------
    //- 計測タグ（body）の呼び出し
    //---------------------------------
    include _includes/_trackingTag_body
    .l-wrapper
      include _includes/_header
      include _includes/_component/_breadcrumb
      main.l-main.u-anim-fadeIn
        //-================================================
        //- ARTICLE START
        //-================================================
        // Article START
        article.l-page
          // Heroセクション
          .l-page__head.u-pt-l
            //- h1.l-page__title お問い合わせ内容確認
            //- .l-page__sub Confirm
            .l-page__intro ご入力内容をご確認の上、送信ボタンを押してください。
          .l-page__body
            section.l-section.-s
              .l-inner.-xs
                form(method="post" action=root+"inquiry-thanks"+extention enctype="multipart/form-data")
                  .c-form__item
                      .c-form__error ※プライバシーポリシーに同意の上、ご送信ください。
                  dl.p-confirm-list.u-mb-xl
                    dt ■ ご要件
                    dd %formData.subject%
                    input(type="hidden" name="subject" value="formData.subject")

                    dt ■ お名前
                    dd %formData.name%
                    input(type="hidden" name="name" value="formData.name")

                    //- dt フリガナ
                    //- dd %formData.kana%
                    //- input(type="hidden" name="kana" value="formData.kana")

                    dt ■ 電話番号
                    dd %formData.tel%
                    input(type="hidden" name="tel" value="formData.tel")
                    
                    dt ■ メールアドレス
                    dd %formData.email%
                    input(type="hidden" name="email" value="formData.email")

                    //- dt 性別
                    //- dd %formData.gender%
                    //- input(type="hidden" name="gender" value="formData.gender")

                    //- dt 生年月日
                    //- dd %formData.birth%
                    //- input(type="hidden" name="birth" value="formData.birth")

                    

                    

                    //- dt 郵便番号
                    //- dd %formData.zip%
                    //- input(type="hidden" name="zip" value="formData.zip")

                    //- dt 住所
                    //- dd %formData.address%
                    //- input(type="hidden" name="address" value="formData.address")

                    //- 会社名（法人系フォームで使用）
                    //- dt 会社名
                    //- dd %formData.company%
                    //- input(type="hidden" name="company" value="formData.company")

                    

                    dt ■ メッセージ
                    dd %formData.message%
                    input(type="hidden" name="message" value="formData.message")

                    //- 複数選択系（チェックボックスの例）
                    //- dt ご希望内容
                    //- dd %formData.options%
                    //- input(type="hidden" name="options" value="formData.options")

                    //- 同意確認
                    //- dt 個人情報取扱いへの同意
                    //- dd %formData.agree%
                    //- input(type="hidden" name="agree" value="formData.agree")

                    //- // 同意事項
                  .c-form__item.u-t-c
                    label.c-form__checkbox
                      input(type="checkbox" name="agree" data-agree-trigger required data-validate="required")
                      span #[a.c-link(href=root+"privacy"+extention) プライバシーポリシー]に同意します＊

                  // 送信ボタン
                  .c-btnBox.u-fd-col.u-gap-l
                    button.c-btn.-submit(type="submit" disabled data-agree-target) 送信する
                    button(type="button" onclick="history.back()") やり直す
                    



        //-================================================
        //- Article END
        //-================================================
        // Article END
      //- include _includes/_sidebar
      //- include _includes/_component/_floatbox
      include _includes/_footer
    //- include _includes/_script
    //---------------------------------
    //- UNIQUE SCRIPT　ページ独自に使用するJS
    //---------------------------------
    block append js
      script(src=root+jsPath + "main.js?ver=1.0.0")
      script(src=root+jsPath + "form.js?ver=1.0.0")