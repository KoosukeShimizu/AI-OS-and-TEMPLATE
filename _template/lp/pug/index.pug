//-================================================
//- サイト共通設定
//-================================================
include _foundation/_global

//- block vars
//---------------
//- ページ設定
//---------------
- var root = './'//ルートパスの指定
- var key = 'home'//条件分岐に使用
- var useNoindex = false//noindexの有無
- var useOgp = true//OGPの有無
- var useAnalytics = true//GAタグの有無
//---------------
//- ページ制御
//---------------
- var pattern = ''// A/Bテストや訴求差分用（例：if pattern =="a"）
- var state = ''// フェーズ切り替え用（例：if state =="phase1"）
- var cpEnd = false// true: キャンペーン終了
- var version = ''// キャッシュ対策用バージョン（例：'?v20260324'）

//---------------
//- ページメタ情報
//---------------
- var pageTitle = ''
- var pageDescription = ''
- var pageKeywords = ''
- var pageOgUrl = ''
- var pageOgTitle = ''
- var pageOgDescription = ''
- var pageOgImage = ''

//---------------
//- スラッグ
//---------------
- var slug = ""

//- ===================================================
//-  ███████╗████████╗ █████╗ ███████╗ ████████╗
//-  ██╔════╝╚══██╔══╝██╔══██╗██╔═══██╗╚══██╔══╝
//-  ███████╗   ██║   ███████║███████╔╝   ██║
//-  ╚════██║   ██║   ██╔══██║██╔═██║     ██║
//-  ███████║   ██║   ██║  ██║██║ ███║    ██║
//-  ╚══════╝   ╚═╝   ╚═╝  ╚═╝╚═╝ ╚══╝    ╚═╝
//- Frontpageは独立設計になる傾向がある
//- ===================================================
doctype html
html(lang='ja')
  head
    include _layout/_head

    //---------------------------------
    //- 計測タグ（head）の呼び出し
    //---------------------------------
    include _layout/_trackingTag_head

  body.l-lp(class={ "is-cpEnd": cpEnd })
    //---------------------------------
    //- 計測タグ（body）の呼び出し
    //---------------------------------
    include _layout/_trackingTag_body

    .l-wrapper

      //-================================================
      //- HEADER（LP用：案件ごとにここを直接編集）
      //-================================================
      header#header.l-header(data-sticky-header)
        .l-header__inner
          h1.l-header__logo
            a(href=root+"")
              img(src=root+imgPath+"common/siteLogo.svg"+version alt=siteName loading="lazy")

      main.l-main
        //-================================================
        //- ARTICLE START
        //-================================================
        article

          //-================================================
          //- HERO
          //-================================================
          section.l-hero.l-section.-xs
            .l-inner.-l
              figure.l-hero__media
                img(src=root+imgPath+"common/dummy-xl.png"+version alt="メインビジュアル" loading="eager")

          //-================================================
          //- SECTION（ベース構造）
          //-================================================
          section.l-section(data-inview="slideUp")
            .l-inner.-l
              .c-subTitle SECTION
              h2.c-heading.-section セクションタイトル
              .c-text ここに説明文が入ります。テンプレでは文章量を控えめにして、案件で差し替えます。

        //-================================================
        //- Article END
        //-================================================

      //-================================================
      //- FLOAT CTA（オプション：不要な案件はブロックごと削除）
      //-================================================
      //- .c-floatbox#floatbox(data-floatbox aria-label="固定アクションメニュー")
      //-   button.c-floatbox__item(
      //-     type="button"
      //-     data-nav-toggle="contactNav"
      //-     aria-controls="contactNav"
      //-     aria-expanded="false"
      //-     aria-label="お問い合わせを開く"
      //-   ) お問い合わせ

      //-================================================
      //- FOOTER（LP用：案件ごとにここを直接編集）
      //-================================================
      footer.l-footer
        .l-footer__head
          a.c-pagetop(href="#header" data-pagetop) PAGE TOP
        .l-footer__body
          .l-footer__logo
            img(src=root+imgPath+"common/siteLogo-footer.svg"+version loading="lazy" alt=siteName)
          //- プライバシーポリシーリンク（案件に合わせて編集）
          nav
            ul
              li
                a(href=root+"privacy"+extension) プライバシーポリシー
        .c-copyright #{copyright}

      include _layout/_script

