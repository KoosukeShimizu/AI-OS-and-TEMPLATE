//-================================================
//- inquiry-thanks.pug（フォーム：完了）
//- - 横展用の最小テンプレ
//- - noindex / OGPなし / analyticsなし
//-================================================

//-================================================
//- サイト共通設定
//-================================================
include _foundation/_global

//-================================================
//- control block（中規模以上：STANDARD）
//-================================================

//---------------
//- パス・識別（必須）
//---------------
- var root = './'
- var key = 'inquiry-thanks'
- var slug = 'inquiry-thanks'
- var parentSlug = 'inquiry'
- var parentTitle = 'お問い合わせ'

//---------------
//- version（静的アセット用：必須）
//---------------
- var version = '?v=20260220'

//---------------
//- head制御
//---------------
- var useNoindex = true
- var useOgp = false
- var useAnalytics = false
- var useLogoH1 = false
- var useBreadcrumb = false

//---------------
//- header制御（テンプレで採用）
//---------------
- var useHeaderMinimal = true
- var useFooterMinimal = true

//---------------
//- schema制御（必要な場合のみON）
//---------------
- var useSchemaWebSite = false
- var useSchemaWebPage = true
- var useSchemaOrganization = false
- var useSchemaBreadcrumb = false
- var useSchemaArticle = false
- var useSchemaFAQ = false

//---------------
//- meta（ページ固有）
//---------------
- var pageTitle = 'お問い合わせ完了'
- var pageDescription = 'お問い合わせを受け付けました。担当者よりご連絡いたします。'
- var pageKeywords = ''

//- ===================================================
//-  ███████╗████████╗ █████╗ ███████╗ ████████╗
//-  ██╔════╝╚══██╔══╝██╔══██╗██╔═══██╗╚══██╔══╝
//-  ███████╗   ██║   ███████║███████╔╝   ██║
//-  ╚════██║   ██║   ██╔══██║██╔═██║     ██║
//-  ███████║   ██║   ██║  ██║██║ ███║    ██║
//-  ╚══════╝   ╚═╝   ╚═╝  ╚═╝╚═╝ ╚══╝    ╚═╝
//- ===================================================
doctype html
html(lang='ja')
  head
    include _layout/_head

    //---------------------------------
    //- UNIQUE CSS　ページ独自に使用するスタイル
    //---------------------------------
    block append css
      //- link(rel='stylesheet' href=root+cssPath+'thanks.css'+version)

    //---------------------------------
    //- SCHEMA　構造化データの呼び出し
    //---------------------------------
    include _foundation/_schema

    //---------------------------------
    //- 計測タグ（head）の呼び出し
    //---------------------------------
    include _layout/_trackingTag_head

  body
    //---------------------------------
    //- 計測タグ（body）の呼び出し
    //---------------------------------
    include _layout/_trackingTag_body

    .l-wrapper
      include _layout/_header

      main.l-main
        //-================================================
        //- ARTICLE START
        //-================================================
        article.l-page

          .l-page__head
            h1.l-page__title #{pageTitle}

          .l-page__body
            section.l-section
              .l-inner.-xxs.u-t-c
                p.c-text お問い合わせありがとうございます。#[br]送信が完了しました。
                p.c-text 後ほど担当者よりご連絡いたします。#[br]（目安：1〜2営業日）

                .c-btnBox.u-mt-l
                  a.c-btn.-underline(href=root+'') トップページへ戻る

        //-================================================
        //- Article END
        //-================================================

      include _layout/_footer

    include _layout/_script

    //---------------------------------
    //- UNIQUE SCRIPT　ページ独自に使用するJS
    //---------------------------------
    block append js
      //- script(src=root+jsPath+'thanks.js'+version)