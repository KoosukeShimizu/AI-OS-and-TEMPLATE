//- ==============================================
//- PAGINATION TEMPLATE（完全ダミー見本）
//- - 本番では currentPage / totalPages で差し替える
//- - href="#" は使用しない
//- ==============================================

nav.c-pagination(aria-label="ページネーション")
  //- Prev（無効状態）
  span.c-pagination__prev.is-disabled(
    aria-disabled="true"
  ) Prev

  ol.c-pagination__list
    //- current
    li.c-pagination__item
      span.c-pagination__link.is-current(
        aria-current="page"
      ) 1

    //- link
    li.c-pagination__item
      a.c-pagination__link(
        href=root+"archive-2"+extension
        aria-label="2ページへ"
      ) 2

    li.c-pagination__item
      a.c-pagination__link(
        href=root+"archive-3"+extension
        aria-label="3ページへ"
      ) 3

    //- more
    li.c-pagination__item
      span.c-pagination__more(
        aria-hidden="true"
      ) …

    li.c-pagination__item
      a.c-pagination__link(
        href=root+"archive-10"+extension
        aria-label="10ページへ"
      ) 10

  //- Next
  a.c-pagination__next(
    href=root+"archive-2"+extension
    aria-label="次のページへ"
  ) Next