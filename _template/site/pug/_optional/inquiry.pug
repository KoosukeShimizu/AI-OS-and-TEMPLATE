//-================================================
//- inquiry.pug（フォーム：お問い合わせ入力）
//- - 横展用の最小テンプレ
//- - confirm / thanks とセット運用想定
//-================================================

//-================================================
//- サイト共通設定
//-================================================
include _foundation/_global

//-================================================
//- control block（中規模以上：STANDARD）
//-================================================

//---------------
//- パス・識別（必須）
//---------------
- var root = './'
- var key = 'inquiry'
- var slug = 'inquiry'
- var parentSlug = ''
- var parentTitle = ''

//---------------
//- version（静的アセット用：必須）
//---------------
- var version = '?v=20260220'

//---------------
//- head制御
//---------------
- var useNoindex = false
- var useOgp = true
- var useAnalytics = true
- var useLogoH1 = false
- var useBreadcrumb = true

//---------------
//- header制御（テンプレで採用）
//---------------
- var useHeaderMinimal = false
- var useFooterMinimal = false

//---------------
//- schema制御（必要な場合のみON）
//---------------
- var useSchemaWebSite = false
- var useSchemaWebPage = true
- var useSchemaOrganization = false
- var useSchemaBreadcrumb = true
- var useSchemaArticle = false
- var useSchemaFAQ = false

//---------------
//- meta（ページ固有）
//---------------
- var pageTitle = 'お問い合わせ'
- var pageDescription = 'お問い合わせはこちらのページから承っております。'
- var pageKeywords = ''

//---------------
//- OGP（useOgp=trueのとき有効）
//---------------
- var pageOgUrl = ''
- var pageOgTitle = pageTitle
- var pageOgDescription = pageDescription
- var pageOgImage = ''

//- ===================================================
//-  ███████╗████████╗ █████╗ ███████╗ ████████╗
//-  ██╔════╝╚══██╔══╝██╔══██╗██╔═══██╗╚══██╔══╝
//-  ███████╗   ██║   ███████║███████╔╝   ██║
//-  ╚════██║   ██║   ██╔══██║██╔═██║     ██║
//-  ███████║   ██║   ██║  ██║██║ ███║    ██║
//-  ╚══════╝   ╚═╝   ╚═╝  ╚═╝╚═╝ ╚══╝    ╚═╝
//- ===================================================
doctype html
html(lang='ja')
  head
    include _layout/_head

    //---------------------------------
    //- UNIQUE CSS　ページ独自に使用するスタイル
    //---------------------------------
    block append css
      //- link(rel='stylesheet' href=root+cssPath+'form.css'+version)

    //---------------------------------
    //- SCHEMA　構造化データの呼び出し
    //---------------------------------
    include _foundation/_schema

    //---------------------------------
    //- 計測タグ（head）の呼び出し
    //---------------------------------
    include _layout/_trackingTag_head

  body
    //---------------------------------
    //- 計測タグ（body）の呼び出し
    //---------------------------------
    include _layout/_trackingTag_body

    .l-wrapper
      include _layout/_header

      if useBreadcrumb === true
        include _component/_breadcrumb

      main.l-main
        //-================================================
        //- ARTICLE START
        //-================================================
        article.l-page

          .l-page__head
            h1.l-page__title #{pageTitle}
            .l-page__sub INQUIRY
            .l-page__intro お問い合わせありがとうございます。#[br]こちらはお問い合わせ入力ページです。

          .l-page__body
            section.l-section.-s
              .l-inner.-xs

                //-================================================
                //- CONTACT FORM（テンプレ最小）
                //- - 案件ごとに項目増減
                //- - バリデーションや詳細UIは案件側で拡張
                //-================================================
                form(method="post" action=root+'inquiry-confirm'+extension)
                  .c-form

                    //- ご用件
                    .c-form__item
                      .c-form__label ご用件
                        span.c-form__require ＊
                      .c-form__body
                        select.c-form__select(name="inquiry" required data-validate="required")
                          option(value="") ご選択ください
                          option(value="サービスについて") サービスについて
                          option(value="料金について") 料金について
                          option(value="その他") その他

                    //- お名前
                    .c-form__item
                      .c-form__label お名前
                        span.c-form__require ＊
                      .c-form__body
                        input.c-form__input(type="text" name="name" placeholder="例：山田 花子" autocomplete="name" required data-validate="required")

                    //- メールアドレス
                    .c-form__item
                      .c-form__label メールアドレス
                        span.c-form__require ＊
                      .c-form__body
                        input.c-form__input(type="email" name="email" placeholder="例：yourname@example.com" autocomplete="email" required data-validate="required email")

                    //- お電話番号（任意）
                    .c-form__item
                      .c-form__label お電話番号
                      .c-form__body
                        input.c-form__input(type="tel" name="tel" placeholder="例：0312345678" autocomplete="tel")

                    //- メッセージ
                    .c-form__item
                      .c-form__label メッセージ
                      .c-form__body
                        textarea.c-form__textarea(name="comment" placeholder="メッセージを具体的にお知らせください。" data-autoresize)

                    //- 送信
                    .c-btnBox.u-gap-l.u-mt-l
                      button.c-btn.-underline(type="submit") 送信内容の確認

        //-================================================
        //- Article END
        //-================================================

      include _layout/_footer

    include _layout/_script

    //---------------------------------
    //- UNIQUE SCRIPT　ページ独自に使用するJS
    //---------------------------------
    block append js
      //- script(src=root+jsPath+'form.js'+version)