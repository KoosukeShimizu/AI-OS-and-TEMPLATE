//-================================================
//- login.pug（ログイン）
//- - noindex
//- - OGPなし
//- - breadcrumbなし
//-================================================

//-================================================
//- サイト共通設定
//-================================================
include _foundation/_global

//-================================================
//- control block（STANDARD）
//-================================================

//---------------
//- パス・識別
//---------------
- var root = './'
- var key = 'login'
- var slug = 'login'
- var parentSlug = ''
- var parentTitle = ''

//---------------
//- version
//---------------
- var version = '?v=20260220'

//---------------
//- head制御
//---------------
- var useNoindex = true
- var useOgp = false
- var useAnalytics = true
- var useLogoH1 = false
- var useBreadcrumb = false

//---------------
//- header / footer 制御
//---------------
- var useHeaderMinimal = true
- var useFooterMinimal = true

//---------------
//- schema制御
//---------------
- var useSchemaWebSite = false
- var useSchemaWebPage = false
- var useSchemaOrganization = false
- var useSchemaBreadcrumb = false
- var useSchemaArticle = false
- var useSchemaFAQ = false

//---------------
//- meta
//---------------
- var pageTitle = 'ログイン'
- var pageDescription = '会員専用マイページへのログインページです。'
- var pageKeywords = ''

//- ===================================================
doctype html
html(lang='ja')
  head
    include _layout/_head
    include _foundation/_schema
    include _layout/_trackingTag_head

  body
    include _layout/_trackingTag_body

    .l-wrapper

      include _layout/_header

      main.l-main
        article.l-page

          .l-page__head
            h1.l-page__title マイページログイン
            .l-page__sub WELCOME

          .l-page__body
            section.l-section.-xxs
              .l-inner.-xxs

                form(method="post" action=root+'mypage'+extension)
                  .c-form

                    //- メールアドレス
                    .c-form__item
                      .c-form__label メールアドレス
                      .c-form__body
                        input.c-form__input.u-fz-l(
                          type="email"
                          name="email"
                          placeholder="例：yourname@example.com"
                          autocomplete="email"
                          required
                          data-validate="required email"
                        )

                    //- パスワード
                    .c-form__item
                      .c-form__label パスワード
                      .c-form__body
                        input.c-form__input.u-fz-l(
                          type="password"
                          name="password"
                          placeholder="パスワードを入力"
                          autocomplete="current-password"
                          required
                          data-password-input
                        )
                        button.c-form__pwToggle(
                          type="button"
                          aria-label="パスワード表示切替"
                          data-password-toggle
                        )

                    //- ログイン情報の記憶
                    .c-form__item.u-t-c
                      label.c-form__checkbox
                        input(type="checkbox" name="remember")
                        span ログイン情報を記憶する

                    //- エラー（JSで制御）
                    //- .c-form__item
                    //-   .c-form__error メールアドレスまたはパスワードが正しくありません

                    .c-btnBox.u-my-l
                      button.c-btn.-underline(type="submit") ログインする

                p.c-text.u-t-c
                  | ・パスワードをお忘れの方は
                  a.c-link(href=root+'password'+extension) こちら

                //- オプション：新規登録・予約導線がある案件で有効化
                //- p.c-text.u-t-c
                //-   | ・初めての方は
                //-   a.c-link(href=root+'register'+extension) 新規登録ページ
                //-   | へお進みください

        //-================================================
        //- Article END
        //-================================================

      //- include _component/_floatbox

      include _layout/_footer

    include _layout/_script

    //---------------------------------
    //- UNIQUE SCRIPT　ページ独自に使用するJS
    //---------------------------------
    block append js
      //- script(src=root+jsPath+'faq.js'+version)