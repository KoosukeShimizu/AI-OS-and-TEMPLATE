//-================================================
//- inquiry-confirm.pug（フォーム：確認）
//- - 横展用の最小テンプレ
//- - noindex / OGPなし / analyticsなし
//-================================================

//-================================================
//- サイト共通設定
//-================================================
include _foundation/_global

//-================================================
//- control block（中規模以上：STANDARD）
//-================================================

//---------------
//- パス・識別（必須）
//---------------
- var root = './'
- var key = 'inquiry-confirm'
- var slug = 'inquiry-confirm'
- var parentSlug = 'inquiry'
- var parentTitle = 'お問い合わせ'

//---------------
//- version（静的アセット用：必須）
//---------------
- var version = '?v=20260220'

//---------------
//- head制御
//---------------
- var useNoindex = true
- var useOgp = false
- var useAnalytics = false
- var useLogoH1 = false
- var useBreadcrumb = false

//---------------
//- header制御（テンプレで採用）
//---------------
- var useHeaderMinimal = true
- var useFooterMinimal = true

//---------------
//- schema制御（必要な場合のみON）
//---------------
- var useSchemaWebSite = false
- var useSchemaWebPage = true
- var useSchemaOrganization = false
- var useSchemaBreadcrumb = false
- var useSchemaArticle = false
- var useSchemaFAQ = false

//---------------
//- meta（ページ固有）
//---------------
- var pageTitle = 'お問い合わせ確認'
- var pageDescription = '入力内容をご確認の上、送信してください。'
- var pageKeywords = ''

//- ===================================================
//-  ███████╗████████╗ █████╗ ███████╗ ████████╗
//-  ██╔════╝╚══██╔══╝██╔══██╗██╔═══██╗╚══██╔══╝
//-  ███████╗   ██║   ███████║███████╔╝   ██║
//-  ╚════██║   ██║   ██╔══██║██╔═██║     ██║
//-  ███████║   ██║   ██║  ██║██║ ███║    ██║
//-  ╚══════╝   ╚═╝   ╚═╝  ╚═╝╚═╝ ╚══╝    ╚═╝
//- ===================================================
doctype html
html(lang='ja')
  head
    include _layout/_head

    //---------------------------------
    //- UNIQUE CSS　ページ独自に使用するスタイル
    //---------------------------------
    block append css
      //- link(rel='stylesheet' href=root+cssPath+'form.css'+version)

    //---------------------------------
    //- SCHEMA　構造化データの呼び出し
    //---------------------------------
    include _foundation/_schema

    //---------------------------------
    //- 計測タグ（head）の呼び出し
    //---------------------------------
    include _layout/_trackingTag_head

  body
    //---------------------------------
    //- 計測タグ（body）の呼び出し
    //---------------------------------
    include _layout/_trackingTag_body

    .l-wrapper
      include _layout/_header

      main.l-main
        //-================================================
        //- ARTICLE START
        //-================================================
        article.l-page

          .l-page__head.u-pt-l
            h1.l-page__title #{pageTitle}
            .l-page__intro ご入力内容をご確認の上、送信してください。

          .l-page__body
            section.l-section.-s
              .l-inner.-xs

                form(method="post" action=root+'inquiry-thanks'+extension)
                  //-================================================
                  //- CONFIRM LIST（ダミー：差し替え前提）
                  //-================================================
                  dl.p-confirmList.u-mb-xl
                    dt ■ ご用件
                    dd %formData.inquiry%
                    input(type="hidden" name="inquiry" value="formData.inquiry")

                    dt ■ お名前
                    dd %formData.name%
                    input(type="hidden" name="name" value="formData.name")

                    dt ■ メールアドレス
                    dd %formData.email%
                    input(type="hidden" name="email" value="formData.email")

                    dt ■ お電話番号
                    dd %formData.tel%
                    input(type="hidden" name="tel" value="formData.tel")

                    dt ■ メッセージ
                    dd %formData.comment%
                    input(type="hidden" name="comment" value="formData.comment")

                  //-================================================
                  //- AGREEMENT（必要な場合のみ：テンプレは保持）
                  //-================================================
                  .c-form__item.u-t-c
                    label.c-form__checkbox
                      input(type="checkbox" name="agree" data-agree-trigger required data-validate="required")
                      span #[a.c-link(href=root+'privacy'+extension) プライバシーポリシー]に同意します＊

                  //-================================================
                  //- SUBMIT
                  //-================================================
                  .c-btnBox.u-fd-col.u-gap-l
                    button.c-btn.-submit(type="submit" disabled data-agree-target) 送信する
                    button.c-btn.-underline(type="button" onclick="history.back()") やり直す

        //-================================================
        //- Article END
        //-================================================

      include _layout/_footer

    include _layout/_script

    //---------------------------------
    //- UNIQUE SCRIPT　ページ独自に使用するJS
    //---------------------------------
    block append js
      //- script(src=root+jsPath+'form.js'+version)