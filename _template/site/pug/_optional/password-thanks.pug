//-================================================
//- サイト共通設定
//-================================================
include _foundation/_global

//-================================================
//- control block（STANDARD）
//-================================================

//---------------
//- パス・識別
//---------------
- var root = './'
- var key = 'password-thanks'
- var slug = 'password-thanks'
- var parentSlug = ''
- var parentTitle = ''

//---------------
//- version
//---------------
- var version = '?v=20260220'

//---------------
//- head制御
//---------------
- var useNoindex = true
- var useOgp = false
- var useAnalytics = false
- var useLogoH1 = false
- var useBreadcrumb = false

//---------------
//- header / footer 制御
//---------------
- var useHeaderMinimal = true
- var useFooterMinimal = true

//---------------
//- schema制御
//---------------
- var useSchemaWebSite = false
- var useSchemaWebPage = false
- var useSchemaOrganization = false
- var useSchemaBreadcrumb = false
- var useSchemaArticle = false
- var useSchemaFAQ = false

//---------------
//- meta
//---------------
- var pageTitle = 'パスワード再設定完了'
- var pageDescription = 'パスワードの再設定が完了しました。'
- var pageKeywords = ''

//- ===================================================
doctype html
html(lang='ja')
  head
    include _layout/_head
    include _foundation/_schema
    include _layout/_trackingTag_head

  body
    include _layout/_trackingTag_body

    .l-wrapper
      include _layout/_header

      main.l-main
        article.l-page

          .l-page__head
            h1.l-page__title パスワード再設定完了
            .l-page__sub COMPLETE

          .l-page__body
            section.l-section.-xxs
              .l-inner.-xxs
                p.c-text パスワードの再設定が完了しました。
                p.c-text.u-mb-l 登録済みのメールアドレスと新しいパスワードでログインしてください。

                .c-btnBox.u-my-l
                  a.c-btn.-underline(href=root+'login'+extension) ログインへ

        //-================================================
        //- Article END
        //-================================================

      //- include _component/_floatbox

      include _layout/_footer

    include _layout/_script

    //---------------------------------
    //- UNIQUE SCRIPT　ページ独自に使用するJS
    //---------------------------------
    block append js
      //- script(src=root+jsPath+'faq.js'+version)