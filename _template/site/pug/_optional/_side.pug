aside.l-side(aria-label="サイドコンテンツ")
  .l-side__inner

    //- Widget: Navigation
    .c-sideWidget
      h2.c-sideWidget__title ナビゲーション
      ul.c-sideWidget__list
        li.c-sideWidget__item
          a(href=root+"page"+extension) 固定ページ
        li.c-sideWidget__item
          a(href=root+"archive"+extension) 記事一覧
        li.c-sideWidget__item
          a(href=root+"inquiry"+extension) お問い合わせ

    //- Widget: Information
    .c-sideWidget
      h2.c-sideWidget__title お知らせ
      ul.c-sideWidget__list
        li.c-sideWidget__item
          a(href=root+"archive"+extension) 最新情報が入ります
        li.c-sideWidget__item
          a(href=root+"page"+extension) キャンペーン情報

    //- Widget: CTA（任意）
    .c-sideWidget
      h2.c-sideWidget__title ご相談はこちら
      a.c-btn-contact(href=root+"inquiry"+extension) お問い合わせ