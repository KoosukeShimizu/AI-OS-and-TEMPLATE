//-================================================
//- password.pug（パスワード再設定）
//- - noindex
//- - OGPなし
//- - breadcrumbなし
//-================================================

//-================================================
//- サイト共通設定
//-================================================
include _foundation/_global

//-================================================
//- control block（STANDARD）
//-================================================

//---------------
//- パス・識別
//---------------
- var root = './'
- var key = 'password'
- var slug = 'password'
- var parentSlug = ''
- var parentTitle = ''

//---------------
//- version
//---------------
- var version = '?v=20260220'

//---------------
//- head制御
//---------------
- var useNoindex = true
- var useOgp = false
- var useAnalytics = true
- var useLogoH1 = false
- var useBreadcrumb = false

//---------------
//- header / footer 制御
//---------------
- var useHeaderMinimal = true
- var useFooterMinimal = true

//---------------
//- schema制御
//---------------
- var useSchemaWebSite = false
- var useSchemaWebPage = false
- var useSchemaOrganization = false
- var useSchemaBreadcrumb = false
- var useSchemaArticle = false
- var useSchemaFAQ = false

//---------------
//- meta
//---------------
- var pageTitle = 'パスワード再設定'
- var pageDescription = '新しいパスワードを設定します。'
- var pageKeywords = ''

//- ===================================================
doctype html
html(lang='ja')
  head
    include _layout/_head
    include _foundation/_schema
    include _layout/_trackingTag_head

  body
    include _layout/_trackingTag_body

    .l-wrapper
      include _layout/_header

      main.l-main
        article.l-page

          .l-page__head
            h1.l-page__title パスワード再設定
            .l-page__sub RESET PASSWORD

          .l-page__body
            section.l-section.-xxs
              .l-inner.-xxs
                p.c-text.u-mb-l 新しく設定するパスワードを入力してください。

                form(method="post" action=root+'password-thanks'+extension)
                  .c-form

                    //- 新しいパスワード
                    .c-form__item
                      .c-form__label 新しいパスワード
                      .c-form__body
                        input.c-form__input.u-fz-l(
                          type="password"
                          name="new-password"
                          placeholder="新しいパスワードを入力"
                          autocomplete="new-password"
                          required
                          data-password-input
                        )
                        button.c-form__pwToggle(
                          type="button"
                          aria-label="パスワード表示切替"
                          data-password-toggle
                        )

                    //- 新しいパスワード（確認）
                    .c-form__item
                      .c-form__label 新しいパスワード（確認）
                      .c-form__body
                        input.c-form__input.u-fz-l(
                          type="password"
                          name="confirm-password"
                          placeholder="確認のため再入力"
                          autocomplete="new-password"
                          required
                          data-password-input
                        )
                        button.c-form__pwToggle(
                          type="button"
                          aria-label="パスワード表示切替"
                          data-password-toggle
                        )

                    //- エラー（JSで制御）
                    //- .c-form__item
                    //-   .c-form__error パスワードが一致しません。もう一度ご確認ください。

                    .c-btnBox.u-my-l
                      button.c-btn.-underline(type="submit") 送信する

        //-================================================
        //- Article END
        //-================================================

      //- include _component/_floatbox

      include _layout/_footer

    include _layout/_script

    //---------------------------------
    //- UNIQUE SCRIPT　ページ独自に使用するJS
    //---------------------------------
    block append js
      //- script(src=root+jsPath+'faq.js'+version)