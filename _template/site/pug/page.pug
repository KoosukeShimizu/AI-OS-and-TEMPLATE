//-================================================
//- page.pug（固定ページ：第2階層メイン）
//- - 横展用の最小テンプレ
//- - コンテンツは .l-page__body 以下に積む
//-================================================

//-================================================
//- サイト共通設定
//-================================================
include _foundation/_global

//-================================================
//- control block（中規模以上：STANDARD）
//-================================================

//---------------
//- パス・識別（必須）
//---------------
- var root = './'
- var key = 'page'
- var slug = 'page'
- var parentSlug = ''
- var parentTitle = ''

//---------------
//- version（静的アセット用：必須）
//---------------
- var version = '?v=20260220'

//---------------
//- head制御
//---------------
- var useNoindex = false
- var useOgp = true
- var useAnalytics = true
- var useLogoH1 = false
- var useBreadcrumb = true

//---------------
//- header制御（テンプレで採用）
//---------------
- var useHeaderMinimal = false
- var useFooterMinimal = false

//---------------
//- schema制御（必要な場合のみON）
//---------------
- var useSchemaWebSite = false
- var useSchemaWebPage = true
- var useSchemaOrganization = false
- var useSchemaBreadcrumb = true
- var useSchemaArticle = false
- var useSchemaFAQ = false

//---------------
//- meta（ページ固有）
//---------------
- var pageTitle = '固定ページタイトル'
- var pageDescription = '固定ページの説明文（未指定ならサイト共通を使用）'
- var pageKeywords = ''

//---------------
//- OGP（useOgp=trueのとき有効）
//---------------
- var pageOgUrl = ''
- var pageOgTitle = pageTitle
- var pageOgDescription = pageDescription
- var pageOgImage = ''

//- ===================================================
//-  ███████╗████████╗ █████╗ ███████╗ ████████╗
//-  ██╔════╝╚══██╔══╝██╔══██╗██╔═══██╗╚══██╔══╝
//-  ███████╗   ██║   ███████║███████╔╝   ██║
//-  ╚════██║   ██║   ██╔══██║██╔═██║     ██║
//-  ███████║   ██║   ██║  ██║██║ ███║    ██║
//-  ╚══════╝   ╚═╝   ╚═╝  ╚═╝╚═╝ ╚══╝    ╚═╝
//- ===================================================
doctype html
html(lang='ja')
  head
    include _layout/_head

    //---------------------------------
    //- UNIQUE CSS　ページ独自に使用するスタイル
    //---------------------------------
    block append css
      //- link(rel='stylesheet' href=root+cssPath+'page.css'+version)

    //---------------------------------
    //- SCHEMA　構造化データの呼び出し
    //---------------------------------
    include _foundation/_schema

    //---------------------------------
    //- 計測タグ（head）の呼び出し
    //---------------------------------
    include _layout/_trackingTag_head

  body
    //---------------------------------
    //- 計測タグ（body）の呼び出し
    //---------------------------------
    include _layout/_trackingTag_body

    .l-wrapper
      include _layout/_header

      if useBreadcrumb === true
        include _component/_breadcrumb

      main.l-main
        //-================================================
        //- ARTICLE START
        //-================================================
        article.l-page

          //- =============================================
          //- PAGE HEADER（テンプレの基本形）
          //- - KVは案件依存。基本は無しでOK
          //- - 英字サブも案件依存。必要な時だけ入れる
          //- =============================================
          .l-page__head
            h1.l-page__title #{pageTitle}
            //- .l-page__sub PAGE SUBTITLE
            //- figure.l-page__kv
            //-   img(src=root+imgPath+'page/page-kv.jpg'+version alt=pageTitle loading='lazy')

          //- =============================================
          //- PAGE BODY（ベースの section セット）
          //- =============================================
          .l-page__body

            //- SECTION: Intro（最小）
            section.l-section.-xs
              .l-inner
                //- h2.c-heading.-h2 セクション見出し
                p.c-text ここに本文が入ります。テンプレとして最低限の文章を置いています。

            //- SECTION: Content（標準）
            section.l-section
              .l-inner
                h2.c-heading.-h2 見出し（h2）
                p.c-text 本文テキスト。#[br]改行が必要なら br を使います。
                ul.c-list.-dot
                  li 箇条書き1
                  li 箇条書き2
                  li 箇条書き3

            //- SECTION: CTA（任意）
            //- - 横展テンプレとして「最後に置ける形」だけ用意
            //- - 使わない案件では丸ごと消してOK
            section.l-section.-xs
              .l-inner.u-t-c
                .c-btnBox
                  a.c-btn.-underline(href=root+'inquiry'+extension) お問い合わせ
                  a.c-btn.-underline(href=root+'archive'+extension) 記事一覧へ

        //-================================================
        //- Article END
        //-================================================

      include _layout/_footer

    include _layout/_script

    //---------------------------------
    //- UNIQUE SCRIPT　ページ独自に使用するJS
    //---------------------------------
    block append js
      //- script(src=root+jsPath+'page.js'+version)