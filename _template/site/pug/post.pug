//-================================================
//- post.pug（詳細ページ：single/post）
//- - 横展用の最小テンプレ
//- - 見出し + 本文（CMS想定） + 戻り導線
//-================================================

//-================================================
//- サイト共通設定
//-================================================
include _foundation/_global

//-================================================
//- control block（中規模以上：STANDARD）
//-================================================

//---------------
//- パス・識別（必須）
//---------------
- var root = './'
- var key = 'post'
- var slug = 'post'
- var parentSlug = 'archive'
- var parentTitle = '記事一覧'

//---------------
//- version（静的アセット用：必須）
//---------------
- var version = '?v=20260220'

//---------------
//- head制御
//---------------
- var useNoindex = false
- var useOgp = true
- var useAnalytics = true
- var useLogoH1 = false
- var useBreadcrumb = true

//---------------
//- header制御（テンプレで採用）
//---------------
- var useHeaderMinimal = false
- var useFooterMinimal = false

//---------------
//- schema制御（必要な場合のみON）
//---------------
- var useSchemaWebSite = false
- var useSchemaWebPage = true
- var useSchemaOrganization = false
- var useSchemaBreadcrumb = true
- var useSchemaArticle = true
- var useSchemaFAQ = false

//---------------
//- meta（ページ固有）
//---------------
- var pageTitle = '記事タイトル（ダミー）'
- var pageDescription = '記事詳細ページです。'
- var pageKeywords = ''

//---------------
//- OGP（useOgp=trueのとき有効）
//---------------
- var pageOgUrl = ''
- var pageOgTitle = pageTitle
- var pageOgDescription = pageDescription
- var pageOgImage = ''

//---------------
//- Article schema 用（最低限）
//- - useSchemaArticle=true のときだけ参照される想定
//---------------
- var articleTitle = pageTitle
- var articleImage = root + imgPath + 'common/ogp.png' + version
- var articleAuthor = siteName
- var datePublished = '2026-02-24'

//- ===================================================
//-  ███████╗████████╗ █████╗ ███████╗ ████████╗
//-  ██╔════╝╚══██╔══╝██╔══██╗██╔═══██╗╚══██╔══╝
//-  ███████╗   ██║   ███████║███████╔╝   ██║
//-  ╚════██║   ██║   ██╔══██║██╔═██║     ██║
//-  ███████║   ██║   ██║  ██║██║ ███║    ██║
//-  ╚══════╝   ╚═╝   ╚═╝  ╚═╝╚═╝ ╚══╝    ╚═╝
//- ===================================================
doctype html
html(lang='ja')
  head
    include _layout/_head

    //---------------------------------
    //- UNIQUE CSS　ページ独自に使用するスタイル
    //---------------------------------
    block append css
      //- link(rel='stylesheet' href=root+cssPath+'post.css'+version)

    //---------------------------------
    //- SCHEMA　構造化データの呼び出し
    //---------------------------------
    include _foundation/_schema

    //---------------------------------
    //- 計測タグ（head）の呼び出し
    //---------------------------------
    include _layout/_trackingTag_head

  body
    //---------------------------------
    //- 計測タグ（body）の呼び出し
    //---------------------------------
    include _layout/_trackingTag_body

    .l-wrapper
      include _layout/_header

      if useBreadcrumb === true
        include _component/_breadcrumb

      main.l-main
        //-================================================
        //- ARTICLE START
        //-================================================
        article.l-article

          // Heroセクション
          .l-article__head
            time.l-article__time(datetime=datePublished)= datePublished
            h1.l-article__title #{pageTitle}
            //- .l-article__tags
            //-   a.c-tag(href=root+"tag"+extension) タグ

            //- figure.l-article__hero
            //-   img(src=root+imgPath+"post/post-hero.jpg"+version loading="lazy" alt=pageTitle)

          .l-article__body
            .l-inner.-s
              .p-editor
                // CMS EDIT CONTENT START
                // ここからはCMSで入力された内容が反映されます。
                //  .p-editor配下はセレクタにスタイルを設定し、クラス付与無しで見た目が整うようにしてください。
                p ここに本文が入ります。テンプレとして最低限の文章を置いています。
                h2 見出し（h2）
                p 本文テキスト。#[br]改行が必要なら br を使います。
                ul
                  li リスト1
                  li リスト2
                  li リスト3
                // CMS EDIT CONTENT END

          .c-btnBox.u-fd-col.u-my-xl
            a.c-btn.-underline.u-mb-l(href=root+'archive'+extension) 一覧へ戻る
            a.c-btn.-underline.u-mb-l(href=root+'inquiry'+extension) お問い合わせ
            a.c-btn.-underline(href=root+'page'+extension) 固定ページへ

        //-================================================
        //- Article END
        //-================================================

      include _layout/_footer

    include _layout/_script

    //---------------------------------
    //- UNIQUE SCRIPT　ページ独自に使用するJS
    //---------------------------------
    block append js
      //- script(src=root+jsPath+'post.js'+version)