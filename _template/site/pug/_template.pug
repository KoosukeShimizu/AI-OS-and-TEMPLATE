//-================================================
//- サイト共通設定
//-================================================
include _foundation/_global

//---------------
//- ページ設定（control block）
//---------------
- var root = './'        //- ルートパスの指定
- var key = ''           //- ナビcurrent制御用
- var slug = ""          //- パンくず：自ページスラッグ
- var parentSlug = ""    //- パンくず：親ページスラッグ（3階層目のみ）
- var parentTitle = ""   //- パンくず：親ページ名（3階層目のみ）

//---------------
//- 表示制御
//---------------
- var useNoindex = false  //- noindexの有無
- var useOgp = true       //- OGPの有無
- var useAnalytics = true //- GAタグの有無
- var useLogoH1 = false   //- ロゴにh1を使うか
- var useBreadcrumb = false //- パンくずを使うか

//---------------
//- 構造化データ制御
//---------------
- var useSchemaWebSite = false
- var useSchemaWebPage = true
- var useSchemaOrganization = false
- var useSchemaBreadcrumb = false
- var useSchemaArticle = false
- var useSchemaFAQ = false

//---------------
//- ページメタ情報
//---------------
- var pageTitle = ''
- var pageDescription = ''
- var pageKeywords = ''
- var pageOgUrl = ''
- var pageOgTitle = ''
- var pageOgDescription = ''
- var pageOgImage = ''

//- ===================================================
//-  ███████╗████████╗ █████╗ ███████╗ ████████╗
//-  ██╔════╝╚══██╔══╝██╔══██╗██╔═══██╗╚══██╔══╝
//-  ███████╗   ██║   ███████║███████╔╝   ██║
//-  ╚════██║   ██║   ██╔══██║██╔═██║     ██║
//-  ███████║   ██║   ██║  ██║██║ ███║    ██║
//-  ╚══════╝   ╚═╝   ╚═╝  ╚═╝╚═╝ ╚══╝    ╚═╝
//- ===================================================
doctype html
html(lang='ja')
  head
    include _layout/_head

    //---------------------------------
    //- UNIQUE CSS　ページ独自に使用するスタイル
    //---------------------------------
    block append css
      //- 例：ページ固有ライブラリのみ追加

    //---------------------------------
    //- SCHEMA　構造化データの呼び出し
    //---------------------------------
    include _foundation/_schema

    //---------------------------------
    //- 計測タグ（head）の呼び出し
    //---------------------------------
    include _layout/_trackingTag_head

  body
    //---------------------------------
    //- 計測タグ（body）の呼び出し
    //---------------------------------
    include _layout/_trackingTag_body

    .l-wrapper
      include _layout/_header

      main.l-main
        //-================================================
        //- ARTICLE START
        //-================================================
        article

          //- コンテンツをここに追加

        //-================================================
        //- Article END
        //-================================================

      //- include _component/_floatbox  //- オプション：浮きボタンが必要な案件で有効化
      include _layout/_footer
      include _layout/_script

    //---------------------------------
    //- UNIQUE SCRIPT　ページ独自に使用するJS
    //---------------------------------
    block append js
      //- ページ固有JSのみ追加
