//-================================================
//- サイト共通設定
//-================================================
include _foundation/_global

//- block vars
//---------------
//- ページ設定
//---------------
- var root = './'//ルートパスの指定
- var key = 'home'//条件分岐に使用
- var useNoindex = false//noindexの有無
- var useOgp = true//OGPの有無
- var useAnalytics = true//GAタグの有無
- var useLogoH1 = true//ロゴにh1を使うか
- var useBreadcrumb = false//パンくずを使うか

//---------------
//- 構造化データ設定
//---------------
- var useSchemaWebSite = true
- var useSchemaWebPage = false
- var useSchemaOrganization = true
- var useSchemaBreadcrumb = false
- var useSchemaArticle = false
- var useSchemaFAQ = false

//---------------
//- ページメタ情報
//---------------
- var pageTitle = ''
- var pageDescription = ''
- var pageKeywords = ''
- var pageOgUrl = ''
- var pageOgTitle = ''
- var pageOgDescription = ''
- var pageOgImage = ''

//---------------
//- パンくず設定
//---------------
- var slug = ""
- var parentSlug = ""
- var parentTitle = ""

//- ===================================================
//-  ███████╗████████╗ █████╗ ███████╗ ████████╗
//-  ██╔════╝╚══██╔══╝██╔══██╗██╔═══██╗╚══██╔══╝
//-  ███████╗   ██║   ███████║███████╔╝   ██║
//-  ╚════██║   ██║   ██╔══██║██╔═██║     ██║
//-  ███████║   ██║   ██║  ██║██║ ███║    ██║
//-  ╚══════╝   ╚═╝   ╚═╝  ╚═╝╚═╝ ╚══╝    ╚═╝
//- Frontpageは独立設計になる傾向がある
//- ===================================================
doctype html
html(lang='ja')
  head
    include _layout/_head

    //---------------------------------
    //- UNIQUE CSS　ページ独自に使用するスタイル
    //---------------------------------
    block append css
      //- 例：ページ固有ライブラリのみ追加

    //---------------------------------
    //- SCHEMA　構造化データの呼び出し
    //---------------------------------
    include _foundation/_schema

    //---------------------------------
    //- 計測タグ（head）の呼び出し
    //---------------------------------
    include _layout/_trackingTag_head

  body.l-home
    //---------------------------------
    //- 計測タグ（body）の呼び出し
    //---------------------------------
    include _layout/_trackingTag_body

    .l-wrapper
      include _layout/_header

      main.l-main
        //-================================================
        //- ARTICLE START
        //-================================================
        article

          //-================================================
          //- HERO
          //-================================================
          section.l-hero.l-section.-xs
            .l-inner.-l
              figure.l-hero__media
                img(src=root+imgPath+"home/hero.jpg"+version alt="メインビジュアル" loading="eager")

          //-================================================
          //- SECTION（ベース構造）
          //-================================================
          section.l-section(data-inview="slideUp")
            .l-inner.-l
              .c-subTitle SECTION
              h2.c-heading.-section セクションタイトル
              .c-text ここに説明文が入ります。テンプレでは文章量を控えめにして、案件で差し替えます。

          //-================================================
          //- NEWS（一覧UI見本）
          //-================================================
          section.l-section.-s(data-inview="slideUp")
            .l-inner.-l
              .c-subTitle NEWS
              h2.c-heading.-section お知らせ
              ul.c-articleList.-text.u-mb-l
                each article in [{href: root + 'post' + extension, date: '2026-02-24', title: 'お知らせタイトルが入ります'}, {href: root + 'post' + extension, date: '2026-02-20', title: 'お知らせタイトルが入ります'}, {href: root + 'post' + extension, date: '2026-02-10', title: 'お知らせタイトルが入ります'}]
                  li.c-articleList__item
                    a.c-articleList__link(href=article.href)
                      time.c-articleList__date(datetime=article.date)= article.date
                      .c-articleList__title= article.title
              .c-btnBox
                a.c-btn.-underline(href=root+'archive'+extension) 一覧を見る

        //-================================================
        //- Article END
        //-================================================

      include _component/_floatbox
      include _layout/_footer
      include _layout/_script

    //---------------------------------
    //- UNIQUE SCRIPT　ページ独自に使用するJS
    //---------------------------------
    block append js
      //- ページ固有JSのみ追加