//- ==============================================
//- FLOATBOX（任意コンポーネント）
//- - 使用時のみ include
//- - CTA補助用（L1通知ではない）
//- ==============================================

.c-floatbox#floatbox(data-floatbox aria-label="固定アクションメニュー")
  //- お問い合わせ（navトグル型）
  button.c-floatbox__item(
    type="button"
    data-nav-toggle="contactNav"
    aria-controls="contactNav"
    aria-expanded="false"
    aria-label="お問い合わせを開く"
  ) お問い合わせ

  //- 予約（通常リンク）
  a.c-floatbox__item(
    href=root+"reserve"+extension
    aria-label="予約ページへ移動"
  ) 予約