//- ==============================================
//- FOOTER TEMPLATE（横展ベース）
//- - 必須: root, imgPath, extension, key, siteName, copyright
//- - 任意: useFooterMinimal (default:false)
//-         useFooterSitemap (default:true)
//-         useFooterSocial (default:false)
//-         facebookUrl/twitterUrl/instagramUrl/lineUrl/youtubeUrl（未設定は出さない）
//- ==============================================

- var useFooterMinimal = (typeof useFooterMinimal !== 'undefined') ? useFooterMinimal : false
- var useFooterSitemap = (typeof useFooterSitemap !== 'undefined') ? useFooterSitemap : true
- var useFooterSocial = (typeof useFooterSocial !== 'undefined') ? useFooterSocial : false

footer.l-footer
  .l-footer__head
    a.c-pagetop(href="#header" data-pagetop) PAGE TOP

  .l-footer__body
    .l-footer__logo
      img(src=root+imgPath+"common/siteLogo-footer.svg"+version loading="lazy" alt=siteName)

    //- confirm等でフッター情報を軽くしたい場合の最小化
    if useFooterMinimal !== true && key !== 'confirm'

      //- SOCIAL（任意：URL未設定は出さない）
      if useFooterSocial === true
        - var socialItems = []
        - socialItems.push({ key: 'instagram', url: (typeof instagramUrl !== 'undefined') ? instagramUrl : '', label: 'instagram' })
        - socialItems.push({ key: 'facebook',  url: (typeof facebookUrl  !== 'undefined') ? facebookUrl  : '', label: 'facebook' })
        - socialItems.push({ key: 'twitter',   url: (typeof twitterUrl   !== 'undefined') ? twitterUrl   : '', label: 'twitter' })
        - socialItems.push({ key: 'line',      url: (typeof lineUrl      !== 'undefined') ? lineUrl      : '', label: 'line' })
        - socialItems.push({ key: 'youtube',   url: (typeof youtubeUrl   !== 'undefined') ? youtubeUrl   : '', label: 'youtube' })
        - socialItems = socialItems.filter(function(item){ return !!item.url })

        if socialItems.length
          nav.c-socialNav(aria-label="Social links")
            ul.c-socialNav__list
              each item in socialItems
                li.c-socialNav__item
                  a(href=item.url target="_blank" rel="noopener noreferrer")
                    img(src=root+imgPath+"common/icons/brand/"+item.key+".svg"+version loading="lazy" alt=item.label)

      //- SITEMAP（任意：テンプレでは代表項目のみ）
      if useFooterSitemap === true
        nav.c-sitemap(aria-label="Sitemap")
          ul.c-sitemap__col
            li.c-sitemap__item
              a(href=root+"") #[span TOP]

            //- 固定ページ代表（page系）
            li.c-sitemap__item
              a(href=root+"page"+extension) #[span 固定ページ]

            //- 投稿/記事代表（archive/post系）
            li.c-sitemap__item
              a(href=root+"archive"+extension) #[span 記事一覧]

            //- お問い合わせ
            li.c-sitemap__item
              a(href=root+"inquiry"+extension) #[span お問い合わせ]

          ul.c-sitemap__col
            li.c-sitemap__item
              a(href=root+"privacy"+extension) #[span プライバシー]

  .c-copyright #{copyright}