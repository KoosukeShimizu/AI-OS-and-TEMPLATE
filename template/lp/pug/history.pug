//-================================================
//- サイト共通設定
//-================================================
include _includes/_foundation/_global

//- block vars
//---------------
//- ページ設定
//---------------
- var root = './' // ルートパスの指定
- var key = 'history' // 条件分岐に使用
- var useNoindex = true // noindexの有無
- var useOgp = false // OGPの有無
- var useAnalytics = true // GAタグの有無
- var useLogoH1 = false // ロゴにh1を使うか
- var useBreadcrumb = false // パンくずを使うか

//---------------
//- 構造化データ設定
//---------------
- var useSchemaWebSite = false
- var useSchemaWebPage = false
- var useSchemaOrganization = false
- var useSchemaBreadcrumb = false
- var useSchemaArticle = false
- var useSchemaFAQ = false

//---------------
//- ページメタ情報
//---------------
- var pageTitle = '予約確認・施術履歴｜N2クリニック'
- var pageDescription = 'N2 CLINIC GINZAのご予約内容および施術履歴をご確認いただけるページです。ご予約の変更やキャンセルもこちらから行えます。'
- var pageKeywords = 'N2クリニック, 予約確認/施術履歴ページ, 会員ページ, ご予約確認, 情報変更'
- var pageOgUrl = ''
- var pageOgTitle = pageTitle
- var pageOgDescription = pageDescription
- var pageOgImage = ''
//---------------
//- パンくず設定
//---------------
- var pageSlug= "history" // ページのスラッグ※末尾に「/」必須
- var parentSlug= "" // ページが3階層目の場合、親ページのスラッグ
- var parentTitle= "" // ページが3階層目の場合、親ページの名前

//- ===================================================
//-  ███████╗████████╗ █████╗ ███████╗ ████████╗
//-  ██╔════╝╚══██╔══╝██╔══██╗██╔═══██╗╚══██╔══╝
//-  ███████╗   ██║   ███████║███████╔╝   ██║
//-  ╚════██║   ██║   ██╔══██║██╔═██║     ██║
//-  ███████║   ██║   ██║  ██║██║ ███║    ██║
//-  ╚══════╝   ╚═╝   ╚═╝  ╚═╝╚═╝ ╚══╝    ╚═╝
//- ===================================================
doctype html
html(lang='ja')
  head
    include _includes/_head
    //---------------------------------
    //- UNIQUE CSS　ページ独自に使用するスタイル
    //---------------------------------
    block append css
      link(href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet")
      link(rel='stylesheet' href=root+cssPath+'main.css?ver=1.0.0' type='text/css' media='all')
    include _includes/_foundation/_schema
    include _includes/_trackingTag_head
  body.p-history
    include _includes/_trackingTag_body
    .l-wrapper
      //- include _includes/_header
      //- include _includes/_component/_breadcrumb
      header.l-header.p-mypage-header
        .p-mypage-header__logo
          a(href=root+"")
            img(src=root+imgPath+"common/logo-ginza.png" alt=siteName)
      main.l-main.u-anim-fadeIn
        //-================================================
        //- ARTICLE START
        //-================================================
        // Article START
        article.l-page
          // Heroセクション
          .l-page__head
            h1.l-page__title 予約確認・施術履歴
            .l-page__sub WELCOME TO N2 ClINIC GINZA
          .l-page__body
            section.l-section.-xxs
              .l-inner.-xxs

                .c-tab(data-tab-group)
                  ul.c-tab__nav.-col-2
                    li.is-active(data-tab-trigger="0") 予約確認
                    li(data-tab-trigger="1") 施術履歴

                  .c-tab__pane.is-active(data-tab-content="0")
                    .u-my-l.u-t-c
                      .c-text ご予約中の施術内容をご確認いただけます。#[br]変更やキャンセルをご希望の場合は、下記よりお手続きください。
                      .c-note ※予約内容に変更がある場合は、前日までにご連絡をお願いいたします。
                      .c-tag.-danger.u-mt-l.u-fz-l 本日ご予約あり
                    
                    // 1件目（本日・変更中）
                    .p-history__card
                      dl.p-history__date
                        dt #[i.c-icon.-user] 受診日
                        dd 2025年8月1日（金）10:30〜
                        dt #[i.c-icon.-document] 施術名
                        dd ・免疫細胞療法カウンセリング
                      .c-tag.-info 変更中

                      //- .c-tag.-info 予約確定
                      //- .c-text 日時：2025年8月1日（金）10:30〜
                      //- .c-text 施術名：免疫細胞療法カウンセリング
                      //- .c-text.u-mt-l ステータス：#[span.u-t-success 変更中]
                      
                      .c-accordion.-dropdown.u-my-l
                        .c-accordion__item
                          button.c-accordion__title(type="button" data-accordion-trigger) 詳細を見る
                          .c-accordion__content(data-accordion-content hidden)
                            dl.p-history__info
                              dt #[i.c-icon.-doctor] 担当医
                              dd 安仁屋　医師
                              dt #[i.c-icon.-comment] 医師コメント
                              dd 前回の治療反応は良好。次回は3週間後が目安です。
                              dt #[i.c-icon.-link] 関連リンク
                              dd #[a.c-link(href=root+"result"+extention) 血液検査結果を確認する]
                              dt #[i.c-icon.-clinic] クリニックコメント
                              dd 細胞の保管期間は26年7月10日までです。残り10本です。

                      .c-btnBox.u-gap-l
                        a.c-btn.-underline(href='#') 変更する
                        a.c-btn.-underline(href='#') キャンセル

                    // 2件目（過去分・予約確定）
                    .p-history__card
                      dl.p-history__date
                        dt #[i.c-icon.-user] 受診日
                        dd 2025年7月10日（木）14:00〜
                        dt #[i.c-icon.-document] 施術名
                        dd ・幹細胞療法
                      .c-tag.-success 予約確定

                      //- .c-text 日時：2025年7月10日（木）14:00〜
                      //- .c-text 施術名：幹細胞療法
                      //- .c-text.u-mt-l ステータス：予約確定

                      .c-accordion.-dropdown.u-my-l
                        .c-accordion__item
                          button.c-accordion__title(type="button" data-accordion-trigger) 詳細を見る
                          .c-accordion__content(data-accordion-content hidden)
                            dl.p-history__info
                              dt #[i.c-icon.-doctor] 担当医
                              dd 安仁屋　医師
                              dt #[i.c-icon.-comment] 医師コメント
                              dd 前回の治療反応は良好。次回は3週間後が目安です。
                              dt #[i.c-icon.-link] 関連リンク
                              dd #[a.c-link(href=root+"result"+extention) 血液検査結果を確認する]
                              dt #[i.c-icon.-clinic] クリニックコメント
                              dd 細胞の保管期間は26年7月10日までです。残り10本です。

                      .c-btnBox.u-gap-l
                        a.c-btn.-underline(href='#') 変更する
                        a.c-btn.-underline(href='#') キャンセル




                  // 施術履歴
                  .c-tab__pane(data-tab-content="1")
                    .u-my-l
                      .c-text.u-t-c 過去に受けた施術の履歴をご確認いただけます。#[br]内容をもとに再予約や確認が必要な場合は、下記よりお進みください。

                    // ▼ 施術履歴カード1（施術完了）
                    .p-history__card
                      .c-tag.-mute 施術完了

                      dl.p-history__date
                        dt #[i.c-icon.-user] 受診日
                        dd 2025年7月10日（木）14:00
                        dt #[i.c-icon.-document] 施術名
                        dd ・幹細胞、免疫細胞カウンセリング#[br]・慢性疼痛（幹細胞数：1億Cell） 都度【脂肪採取・1回目投与】

                      .c-accordion.-dropdown.u-my-l
                        .c-accordion__item
                          button.c-accordion__title(type="button" data-accordion-trigger) 詳細を見る
                          .c-accordion__content(data-accordion-content hidden)
                            dl.p-history__info
                              dt #[i.c-icon.-doctor] 担当医
                              dd 安仁屋　医師
                              dt #[i.c-icon.-comment] 医師コメント
                              dd 前回の治療反応は良好。次回は3週間後が目安です。
                              dt #[i.c-icon.-link] 関連リンク
                              dd #[a.c-link(href=root+"result"+extention) 血液検査結果を確認する]
                              dt #[i.c-icon.-clinic] クリニックコメント
                              dd 細胞の保管期間は26年7月10日までです。残り10本です。

                      .c-btnBox.u-gap-l
                        a.c-btn.-underline(href='#') 再予約する

                    // ▼ 施術履歴カード2（キャンセル済）
                    .p-history__card
                      .c-tag.-mute キャンセル済

                      dl.p-history__date
                        dt #[i.c-icon.-user] 受診日
                        dd 2025年6月2日（金）14:00
                        dt #[i.c-icon.-document] 施術名
                        dd ・幹細胞、免疫細胞カウンセリング

                      //- .p-history__date
                      //-   i.c-icon.-user 受診日
                      //-   span 2025年6月2日（金）14:00

                      //- .p-history__menu
                      //-   i.c-icon.-document 施術名
                      //-   ul
                      //-     li ・幹細胞、免疫細胞カウンセリング

                      .c-btnBox.u-gap-l
                        a.c-btn.-underline(href='#') 再予約する



                    // ▼ さらに履歴を確認する
                    .c-btnBox
                      button.c-btn.-underline(type="button") さらに履歴を確認する



        //-================================================
        //- Article END
        //-================================================
        // Article END
      //- include _includes/_sidebar
      //- include _includes/_component/_floatbox
      include _includes/_footer
    //- include _includes/_script
    //---------------------------------
    //- UNIQUE SCRIPT　ページ独自に使用するJS
    //---------------------------------
    block append js
      script(src=root+jsPath + "main.js?ver=1.0.0")