//-================================================
//- faq.pug（FAQ：よくある質問）
//- - 横展用の最小テンプレ
//- - FAQPage（JSON-LD）は _schema 側で出す想定
//-================================================

//-================================================
//- サイト共通設定
//-================================================
include _foundation/_global

//-================================================
//- control block（中規模以上：STANDARD）
//-================================================

//---------------
//- パス・識別（必須）
//---------------
- var root = './'
- var key = 'faq'
- var slug = 'faq'
- var parentSlug = ''
- var parentTitle = ''

//---------------
//- version（静的アセット用：必須）
//---------------
- var version = '?v=20260220'

//---------------
//- head制御
//---------------
- var useNoindex = false
- var useOgp = true
- var useAnalytics = true
- var useLogoH1 = false
- var useBreadcrumb = true

//---------------
//- header制御（テンプレで採用）
//---------------
- var useHeaderMinimal = false
- var useFooterMinimal = false

//---------------
//- schema制御（必要な場合のみON）
//---------------
- var useSchemaWebSite = false
- var useSchemaWebPage = true
- var useSchemaOrganization = false
- var useSchemaBreadcrumb = true
- var useSchemaArticle = false
- var useSchemaFAQ = true

//---------------
//- meta（ページ固有）
//---------------
- var pageTitle = 'ご質問集'
- var pageDescription = 'よくあるご質問をまとめています。'
- var pageKeywords = ''

//---------------
//- OGP（useOgp=trueのとき有効）
//---------------
- var pageOgUrl = ''
- var pageOgTitle = pageTitle
- var pageOgDescription = pageDescription
- var pageOgImage = ''

//---------------
//- FAQ schema 用（最小：Q&A 3件）
//- - _schema 側の canSchemaFAQ に合わせる
//- - ページ側では「代表3件」を置き、実FAQは別で持つ運用にする
//---------------
- var faqQ1 = '予約は必要ですか？'
//- var faqA1 = '当院は完全予約制です。事前にご予約のうえご来院ください。'
- var faqA1 = '完全予約制のため、事前にご予約をお願いします。'
- var faqQ2 = '支払い方法は何がありますか？'
//- var faqA2 = '各種クレジットカードに対応しています。'
- var faqA2 = 'クレジットカード等に対応しています。'
- var faqQ3 = '当日の持ち物はありますか？'
//- var faqA3 = '初回は本人確認書類をご持参ください。'
- var faqA3 = '初回は本人確認書類をご持参ください。'

//---------------
//- FAQ表示用データ（ダミー）
//- - 横展テンプレでは「カテゴリ×アコーディオン」の形だけ残す
//---------------
- var faqData = [{ category: 'カテゴリA', list: [{ question: '質問が入ります（ダミー）', answer: '回答が入ります（ダミー）。' }, { question: '質問が入ります（ダミー）', answer: '回答が入ります（ダミー）。' }] }, { category: 'カテゴリB', list: [{ question: '質問が入ります（ダミー）', answer: '回答が入ります（ダミー）。' }, { question: '質問が入ります（ダミー）', answer: '回答が入ります（ダミー）。' }] }, { category: 'カテゴリC', list: [{ question: '質問が入ります（ダミー）', answer: '回答が入ります（ダミー）。' }] }]

//- ===================================================
//-  ███████╗████████╗ █████╗ ███████╗ ████████╗
//-  ██╔════╝╚══██╔══╝██╔══██╗██╔═══██╗╚══██╔══╝
//-  ███████╗   ██║   ███████║███████╔╝   ██║
//-  ╚════██║   ██║   ██╔══██║██╔═██║     ██║
//-  ███████║   ██║   ██║  ██║██║ ███║    ██║
//-  ╚══════╝   ╚═╝   ╚═╝  ╚═╝╚═╝ ╚══╝    ╚═╝
//- ===================================================
doctype html
html(lang='ja')
  head
    include _layout/_head

    //---------------------------------
    //- UNIQUE CSS　ページ独自に使用するスタイル
    //---------------------------------
    block append css
      //- link(rel='stylesheet' href=root+cssPath+'faq.css'+version)

    //---------------------------------
    //- SCHEMA　構造化データの呼び出し
    //---------------------------------
    include _foundation/_schema

    //---------------------------------
    //- 計測タグ（head）の呼び出し
    //---------------------------------
    include _layout/_trackingTag_head

  body
    //---------------------------------
    //- 計測タグ（body）の呼び出し
    //---------------------------------
    include _layout/_trackingTag_body

    .l-wrapper
      include _layout/_header

      if useBreadcrumb === true
        include _component/_breadcrumb

      main.l-main
        //-================================================
        //- ARTICLE START
        //-================================================
        article.l-page

          .l-page__head
            h1.l-page__title #{pageTitle}
            .l-page__sub FAQ
            //- .l-page__intro 導入説明

          .l-page__body
            section.l-section.-s
              .l-inner

                .c-tab(data-tab-group="faq")
                  ul.c-tab__nav.-col-3
                    each cat, idx in faqData
                      li(class=(idx === 0 ? 'is-active' : ''), data-tab-trigger=idx) #{cat.category}

                  each cat, idx in faqData
                    .c-tab__pane(class=(idx === 0 ? 'is-active' : ''), data-tab-content=idx)
                      .c-accordion.-list
                        each item in cat.list
                          .c-accordion__item
                            button.c-accordion__title(type="button", data-accordion-trigger)
                              span.c-accordion__text #{item.question}
                            .c-accordion__content(data-accordion-content hidden)
                              p #{item.answer}

            section.l-section.-xs
              .l-inner
                .c-text.-center.u-mb-l その他ご質問があればお気軽にお問い合わせください。
                .c-btnBox.u-fd-col
                  a.c-btn.-underline.u-mb-l(href=root+'inquiry'+extension) お問い合わせ

        //-================================================
        //- Article END
        //-================================================

      //- include _component/_floatbox

      include _layout/_footer

    include _layout/_script

    //---------------------------------
    //- UNIQUE SCRIPT　ページ独自に使用するJS
    //---------------------------------
    block append js
      //- script(src=root+jsPath+'faq.js'+version)