//-================================================
//- archive.pug（一覧ページ：archive）
//- - 横展用の最小テンプレ
//- - 一覧UI + ページネーションだけを持つ
//-================================================

//-================================================
//- サイト共通設定
//-================================================
include _foundation/_global

//-================================================
//- control block（中規模以上：STANDARD）
//-================================================

//---------------
//- パス・識別（必須）
//---------------
- var root = './'
- var key = 'archive'
- var slug = 'archive'
- var parentSlug = ''
- var parentTitle = ''

//---------------
//- version（静的アセット用：必須）
//---------------
- var version = '?v=20260220'

//---------------
//- head制御
//---------------
- var useNoindex = false
- var useOgp = true
- var useAnalytics = true
- var useLogoH1 = false
- var useBreadcrumb = true

//---------------
//- header制御（テンプレで採用）
//---------------
- var useHeaderMinimal = false
- var useFooterMinimal = false

//---------------
//- schema制御（必要な場合のみON）
//---------------
- var useSchemaWebSite = false
- var useSchemaWebPage = true
- var useSchemaOrganization = false
- var useSchemaBreadcrumb = true
- var useSchemaArticle = false
- var useSchemaFAQ = false

//---------------
//- meta（ページ固有）
//---------------
- var pageTitle = '記事一覧'
- var pageDescription = '記事一覧ページです。'
- var pageKeywords = ''

//---------------
//- OGP（useOgp=trueのとき有効）
//---------------
- var pageOgUrl = ''
- var pageOgTitle = pageTitle
- var pageOgDescription = pageDescription
- var pageOgImage = ''

//- ===================================================
//-  ███████╗████████╗ █████╗ ███████╗ ████████╗
//-  ██╔════╝╚══██╔══╝██╔══██╗██╔═══██╗╚══██╔══╝
//-  ███████╗   ██║   ███████║███████╔╝   ██║
//-  ╚════██║   ██║   ██╔══██║██╔═██║     ██║
//-  ███████║   ██║   ██║  ██║██║ ███║    ██║
//-  ╚══════╝   ╚═╝   ╚═╝  ╚═╝╚═╝ ╚══╝    ╚═╝
//- ===================================================
doctype html
html(lang='ja')
  head
    include _layout/_head

    //---------------------------------
    //- UNIQUE CSS　ページ独自に使用するスタイル
    //---------------------------------
    block append css
      //- link(rel='stylesheet' href=root+cssPath+'archive.css'+version)

    //---------------------------------
    //- SCHEMA　構造化データの呼び出し
    //---------------------------------
    include _foundation/_schema

    //---------------------------------
    //- 計測タグ（head）の呼び出し
    //---------------------------------
    include _layout/_trackingTag_head

  body
    //---------------------------------
    //- 計測タグ（body）の呼び出し
    //---------------------------------
    include _layout/_trackingTag_body

    .l-wrapper
      include _layout/_header

      if useBreadcrumb === true
        include _component/_breadcrumb

      main.l-main
        //-================================================
        //- ARTICLE START
        //-================================================
        article.l-page

          // Heroセクション
          .l-page__head
            h1.l-page__title #{pageTitle}
            //- .l-page__sub ARCHIVE
            //- .l-page__intro 一覧の導入文を入れる場合はここに置く

          .l-page__body
            section.l-section.-s
              .l-inner.-l
                //-================================================
                //- 記事データ定義（仮データ）
                //-================================================
                - var archiveData = [{ href: root + 'post' + extension, thumb: 'noimage.jpg', date: '2026-02-01', title: 'タイトルが入ります' },{ href: root + 'post' + extension, thumb: 'noimage.jpg', date: '2026-02-02', title: 'タイトルが入ります' },{ href: root + 'post' + extension, thumb: 'noimage.jpg', date: '2026-02-03', title: 'タイトルが入ります' },{ href: root + 'post' + extension, thumb: 'noimage.jpg', date: '2026-02-04', title: 'タイトルが入ります' },{ href: root + 'post' + extension, thumb: 'noimage.jpg', date: '2026-02-05', title: 'タイトルが入ります' },{ href: root + 'post' + extension, thumb: 'noimage.jpg', date: '2026-02-06', title: 'タイトルが入ります' }]

                //-================================================
                //- レンダリング部（カード型一覧の基本例）
                //-================================================
                ul.c-articleList.-card.u-mb-xl
                  each article in archiveData
                    li.c-articleList__item
                      a.c-articleList__link(href=article.href)
                      figure.c-articleList__thumb
                        img(src=root + imgPath + 'common/' + article.thumb + version, alt='サムネイル' loading='lazy')
                      .c-articleList__body
                        .c-articleList__date
                          time(datetime=article.date)= article.date
                        .c-articleList__title= article.title
                        .c-btn.-underline 詳しく見る

                include _component/_pagination

            section.l-section.-xs
              .l-inner
                .c-btnBox.u-fd-col
                  a.c-btn.-underline.u-mb-l(href=root+'inquiry'+extension) お問い合わせ
                  a.c-btn.-underline(href=root+'page'+extension) 固定ページへ

        //-================================================
        //- Article END
        //-================================================

      include _layout/_footer

    include _layout/_script

    //---------------------------------
    //- UNIQUE SCRIPT　ページ独自に使用するJS
    //---------------------------------
    block append js
      //- script(src=root+jsPath+'archive.js'+version)