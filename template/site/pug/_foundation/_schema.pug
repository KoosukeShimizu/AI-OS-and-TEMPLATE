// STRUCTURED DATA (SCHEMA)

// schemaPageUrl（pageUrl優先 → siteUrl + slug）
// ※ pageSlug は旧互換（移行期間のみ）。最終的に削除して slug に統一する。
- var schemaPageUrl = (typeof pageUrl !== 'undefined' && pageUrl) ? pageUrl : joinUrl((typeof siteUrl !== 'undefined' ? siteUrl : ''), ((typeof slug !== 'undefined' && slug) ? slug : ((typeof pageSlug !== 'undefined' && pageSlug) ? pageSlug : '')))

// Article / FAQ の出力条件
- var canSchemaArticle = (typeof articleTitle !== 'undefined' && articleTitle) && (typeof articleImage !== 'undefined' && articleImage) && (typeof articleAuthor !== 'undefined' && articleAuthor) && (typeof datePublished !== 'undefined' && datePublished)
- var canSchemaFAQ = (typeof faqQ1 !== 'undefined' && faqQ1) && (typeof faqA1 !== 'undefined' && faqA1) && (typeof faqQ2 !== 'undefined' && faqQ2) && (typeof faqA2 !== 'undefined' && faqA2) && (typeof faqQ3 !== 'undefined' && faqQ3) && (typeof faqA3 !== 'undefined' && faqA3)

// sameAs（未定義でも落ちない）
- var schemaSameAs = [facebookUrl, twitterUrl, instagramUrl, lineUrl, youtubeUrl].filter(function(url){ return !!url; })

// Breadcrumb itemListElement を配列で組む（JSON事故防止）
- var breadcrumbItems = []
- breadcrumbItems.push({ "@type":"ListItem", "position": 1, "item": { "@id": siteUrl, "name": "ホーム" } })
- if (typeof parentSlug !== 'undefined' && parentSlug) {
-   breadcrumbItems.push({ "@type":"ListItem", "position": 2, "item": { "@id": joinUrl(siteUrl, parentSlug), "name": (typeof parentTitle !== 'undefined' && parentTitle) ? parentTitle : "" } })
-   breadcrumbItems.push({ "@type":"ListItem", "position": 3, "item": { "@id": schemaPageUrl, "name": (typeof pageTitle !== 'undefined' && pageTitle) ? pageTitle : "" } })
- } else {
-   breadcrumbItems.push({ "@type":"ListItem", "position": 2, "item": { "@id": schemaPageUrl, "name": (typeof pageTitle !== 'undefined' && pageTitle) ? pageTitle : "" } })
- }

//- WebSite（検索対応付き）
if useSchemaWebSite
  script(type="application/ld+json").
    {
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "#{siteName}",
      "url": "#{siteUrl}",
      "potentialAction": {
        "@type": "SearchAction",
        "target": "#{joinUrl(siteUrl, 'search')}?q={search_term_string}",
        "query-input": "required name=search_term_string"
      }
    }

//- WebPage
if useSchemaWebPage
  script(type="application/ld+json").
    {
      "@context": "https://schema.org",
      "@type": "WebPage",
      "name": "#{pageTitle}",
      "url": "#{schemaPageUrl}",
      "description": "#{pageDescription}"
    }

//- Organization
if useSchemaOrganization
  script(type="application/ld+json").
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "#{siteName}",
      "url": "#{siteUrl}",
      "logo": "#{siteLogo}",
      "email": "#{email}",
      "telephone": "#{telephone}",
      "address": {
        "@type": "PostalAddress",
        "addressCountry": "JP",
        "postalCode": "#{postalCode}",
        "addressRegion": "#{addressRegion}",
        "addressLocality": "#{addressLocality}",
        "streetAddress": "#{streetAddress}"
      },
      "sameAs": #{JSON.stringify(schemaSameAs)}
    }

//- BreadcrumbList
if useSchemaBreadcrumb
  script(type="application/ld+json").
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": #{JSON.stringify(breadcrumbItems)}
    }

//- Article
if useSchemaArticle && canSchemaArticle
  script(type="application/ld+json").
    {
      "@context": "https://schema.org",
      "@type": "Article",
      "headline": "#{articleTitle}",
      "image": "#{articleImage}",
      "author": { "@type": "Person", "name": "#{articleAuthor}" },
      "publisher": {
        "@type": "Organization",
        "name": "#{siteName}",
        "logo": { "@type": "ImageObject", "url": "#{siteLogo}" }
      },
      "datePublished": "#{datePublished}"
    }

//- FAQPage
if useSchemaFAQ && canSchemaFAQ
  script(type="application/ld+json").
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "#{faqQ1}",
          "acceptedAnswer": { "@type": "Answer", "text": "#{faqA1}" }
        },
        {
          "@type": "Question",
          "name": "#{faqQ2}",
          "acceptedAnswer": { "@type": "Answer", "text": "#{faqA2}" }
        },
        {
          "@type": "Question",
          "name": "#{faqQ3}",
          "acceptedAnswer": { "@type": "Answer", "text": "#{faqA3}" }
        }
      ]
    }